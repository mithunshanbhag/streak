@inject ICheckinProofService CheckinProofService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6"
                 Class="mb-2">
            @DialogTitleText
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <MudAlert Severity="Severity.Error"
                          Variant="Variant.Outlined"
                          Dense="true">
                    @_errorMessage
                </MudAlert>
            }

            <MudStack Spacing="1">
                <MudTextField T="string"
                              Margin="Margin.Dense"
                              Clearable="true"
                              Immediate="true"
                              @bind-Value="_note"
                              Placeholder="@NotePlaceholder"
                              MaxLength="@CoreConstants.CheckinNotesMaxLength"/>

                <MudStack Row="true"
                          Justify="Justify.FlexEnd"
                          Spacing="2">
                    <MudText Typo="Typo.caption"
                             Style="@SupportingTextStyle">
                        @NoteCounterText
                    </MudText>
                </MudStack>
            </MudStack>

            <MudStack Spacing="1">
                <MudStack Row="true"
                           Spacing="1">
                    @if (CanUseCamera)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   StartIcon="@UseCameraIcon"
                                   Style="@ProofActionButtonStyle"
                                   OnClick="HandleUseCameraClickAsync">
                            @UseCameraButtonText
                        </MudButton>
                    }
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@ChoosePhotoIcon"
                               Style="@ProofActionButtonStyle"
                               OnClick="HandleChoosePhotoClickAsync">
                        @ChoosePhotoButtonText
                    </MudButton>
                </MudStack>

                @if (_selectedProof is null)
                {
                    <MudPaper Elevation="0"
                              Class="pa-3 rounded-lg"
                              Style="@EmptyPreviewPanelStyle">
                        <MudStack AlignItems="AlignItems.Center"
                                  Justify="Justify.Center"
                                  Spacing="1"
                                  Style="@EmptyPreviewContentStyle">
                            <MudIcon Icon="@EmptyPreviewIcon"
                                     Size="Size.Large"
                                     Style="@EmptyPreviewIconStyle"/>
                            <MudText Typo="Typo.body2"
                                     Align="Align.Center">
                                @EmptyPreviewText
                            </MudText>
                        </MudStack>
                    </MudPaper>
                }
                else
                {
                    <MudPaper Elevation="0"
                              Class="pa-3 rounded-lg"
                              Style="@PopulatedPreviewPanelStyle">
                        <MudStack Spacing="2">
                            <div style="@PreviewImageContainerStyle">
                                <img src="@_selectedProof.PreviewDataUrl"
                                     alt="@SelectedPreviewAltText"
                                     style="@PreviewImageStyle" />
                            </div>

                            <MudStack Row="true"
                                      AlignItems="AlignItems.Start"
                                      Justify="Justify.SpaceBetween"
                                      Spacing="1">
                                <MudStack Spacing="0"
                                          Class="flex-1">
                                    <MudText Typo="Typo.body2">
                                        @_selectedProof.DisplayName
                                    </MudText>
                                    <MudText Typo="Typo.caption"
                                             Style="@SupportingTextStyle">
                                        @SelectedProofMetadataText
                                    </MudText>
                                </MudStack>
                                <MudIconButton Icon="@RemoveSelectedProofIcon"
                                               Size="Size.Small"
                                               Color="Color.Default"
                                               AriaLabel="@RemoveSelectedPictureAriaLabel"
                                               OnClick="ClearSelectedProof" />
                            </MudStack>

                            <MudStack Row="true"
                                      Spacing="1">
                                <MudButton Variant="Variant.Text"
                                           OnClick="HandleReplacePhotoClickAsync">
                                    @ReplacePhotoButtonText
                                </MudButton>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                }
            </MudStack>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text"
                   OnClick="Cancel">
            @CancelButtonText
        </MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="ConfirmCheckinAsync">
            @ConfirmButtonText
        </MudButton>
    </DialogActions>
</MudDialog>

@code
{
    #region Parameters

    [Parameter] [EditorRequired] public string HabitName { get; set; } = string.Empty;

    [Parameter] [EditorRequired] public int HabitId { get; set; }

    [Parameter] [EditorRequired] public string CheckinDate { get; set; } = string.Empty;

    [CascadingParameter] private IMudDialogInstance? MudDialogInstance { get; set; }

    #endregion

    #region Private Fields, Properties

    private string _note = string.Empty;
    private string? _errorMessage;
    private CheckinProofSelection? _selectedProof;

    #endregion

    #region Lifecycle Methods

    protected override async Task OnInitializedAsync()
    {
        if (MudDialogInstance is not null)
        {
            await MudDialogInstance.SetOptionsAsync(CreateDialogOptions());
        }
    }

    protected override void OnParametersSet()
    {
        ArgumentException.ThrowIfNullOrWhiteSpace(HabitName);
        ArgumentOutOfRangeException.ThrowIfNegativeOrZero(HabitId);
        ArgumentException.ThrowIfNullOrWhiteSpace(CheckinDate);
    }

    #endregion

    #region Event Handlers

    private void Cancel()
    {
        MudDialogInstance?.Cancel();
    }

    private async Task ConfirmCheckinAsync()
    {
        _errorMessage = null;

        try
        {
            var persistedProof = _selectedProof is null
                ? null
                : await CheckinProofService.PersistAsync(_selectedProof, HabitId, CheckinDate);

            MudDialogInstance?.Close(DialogResult.Ok(CheckinDialogResult.Create(_note, persistedProof)));
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task HandleUseCameraClickAsync()
    {
        await SelectProofAsync(() => CheckinProofService.CapturePhotoAsync());
    }

    private async Task HandleChoosePhotoClickAsync()
    {
        await SelectProofAsync(() => CheckinProofService.PickPhotoAsync());
    }

    private async Task HandleReplacePhotoClickAsync()
    {
        await SelectProofAsync(() => CheckinProofService.PickPhotoAsync());
    }

    private void ClearSelectedProof()
    {
        _selectedProof = null;
        _errorMessage = null;
    }

    #endregion

    #region Private Helper Methods

    private static DialogOptions CreateDialogOptions()
    {
        return new DialogOptions
        {
            BackdropClick = false,
            CloseButton = true,
            CloseOnEscapeKey = true,
            FullWidth = true,
            MaxWidth = MaxWidth.ExtraSmall
        };
    }

    private async Task SelectProofAsync(Func<Task<CheckinProofSelection?>> selectionFactory)
    {
        _errorMessage = null;

        try
        {
            var selection = await selectionFactory();
            if (selection is not null)
                _selectedProof = selection;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private static string FormatFileSize(long fileSizeBytes)
    {
        return $"{fileSizeBytes / (1024d * 1024d):0.#} MB";
    }

    #endregion

    #region CSS Style Properties

    private const string SupportingTextStyle = "color: var(--mud-palette-text-secondary);";

    private const string ProofActionButtonStyle = "flex: 1 1 0; border-radius: 12px;";

    private const string EmptyPreviewPanelStyle = "border: 1px solid var(--mud-palette-lines-default); background-color: var(--mud-palette-background-grey);";

    private const string EmptyPreviewContentStyle = "min-height: 120px;";

    private const string EmptyPreviewIconStyle = "color: var(--mud-palette-text-secondary);";

    private const string PopulatedPreviewPanelStyle = "border: 1px solid var(--mud-palette-lines-default); background-color: var(--mud-palette-background-grey);";

    private const string PreviewImageContainerStyle = "width: 100%; aspect-ratio: 4 / 3; overflow: hidden; border-radius: 12px; background-color: var(--mud-palette-background-grey);";

    private const string PreviewImageStyle = "width: 100%; height: 100%; object-fit: cover; display: block;";

    #endregion

    #region Text, Label Properties

    private string DialogTitleText => $"Check in '{HabitName}'";

    private const string NotePlaceholder = "Add a note (optional)";

    private const string CancelButtonText = "Cancel";

    private const string ConfirmButtonText = "Save check-in";

    private const string UseCameraButtonText = "Camera";

    private const string ChoosePhotoButtonText = "Gallery";

    private const string EmptyPreviewText = "No picture selected";

    private const string ReplacePhotoButtonText = "Replace";

    private const string UseCameraIcon = Icons.Material.Filled.PhotoCamera;

    private const string ChoosePhotoIcon = Icons.Material.Filled.PhotoLibrary;

    private const string EmptyPreviewIcon = Icons.Material.Filled.Image;

    private const string RemoveSelectedProofIcon = Icons.Material.Filled.Close;

    private const string SelectedPreviewAltText = "Selected picture preview";

    private const string RemoveSelectedPictureAriaLabel = "Remove selected picture";

    private bool CanUseCamera => CheckinProofService.SupportsCameraCapture;

    private string NoteCounterText => $"{_note.Length} / {CoreConstants.CheckinNotesMaxLength}";

    private string SelectedProofMetadataText => _selectedProof is null
        ? string.Empty
        : $"{FormatFileSize(_selectedProof.FileSizeBytes)} · {_selectedProof.SourceDescription}";

    #endregion

}
