<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6"
                 Class="mb-2">
            @DialogTitleText
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.body2">
                @DialogMessageText
            </MudText>

            <MudStack Spacing="1">
                <MudText Typo="Typo.caption"
                         Style="@CaptionTextStyle">
                    @NoteLabel
                </MudText>

                <MudTextField T="string"
                              Margin="Margin.Dense"
                              Clearable="true"
                              Immediate="true"
                              @bind-Value="_note"
                              Placeholder="@NotePlaceholder"
                              MaxLength="@CoreConstants.CheckinNotesMaxLength"/>

                <MudStack Row="true"
                          Justify="Justify.SpaceBetween"
                          Spacing="2">
                    <MudText Typo="Typo.caption"
                             Style="@SupportingTextStyle">
                        @NoteHelperText
                    </MudText>
                    <MudText Typo="Typo.caption"
                             Style="@SupportingTextStyle">
                        @NoteCounterText
                    </MudText>
                </MudStack>
            </MudStack>

            <MudStack Spacing="1">
                <MudText Typo="Typo.caption"
                         Style="@CaptionTextStyle">
                    @ProofSectionLabel
                </MudText>
                <MudText Typo="Typo.caption"
                         Style="@SupportingTextStyle">
                    @ProofSectionCaption
                </MudText>

                <MudStack Row="true"
                          Spacing="1">
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@UseCameraIcon"
                               Style="@ProofActionButtonStyle"
                               OnClick="HandleUseCameraClick">
                        @UseCameraButtonText
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@ChoosePhotoIcon"
                               Style="@ProofActionButtonStyle"
                               OnClick="HandleChoosePhotoClick">
                        @ChoosePhotoButtonText
                    </MudButton>
                </MudStack>

                <MudPaper Elevation="0"
                          Class="pa-3 rounded-lg"
                          Style="@EmptyPreviewPanelStyle">
                    <MudStack AlignItems="AlignItems.Center"
                              Justify="Justify.Center"
                              Spacing="1"
                              Style="@EmptyPreviewContentStyle">
                        <MudIcon Icon="@EmptyPreviewIcon"
                                 Size="Size.Large"
                                 Style="@EmptyPreviewIconStyle"/>
                        <MudText Typo="Typo.body2"
                                 Align="Align.Center">
                            @EmptyPreviewText
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudStack>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text"
                   OnClick="Cancel">
            @CancelButtonText
        </MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="ConfirmCheckin">
            @ConfirmButtonText
        </MudButton>
    </DialogActions>
</MudDialog>

@code
{

    #region Parameters

    [Parameter] [EditorRequired] public string HabitName { get; set; } = string.Empty;

    [CascadingParameter] private IMudDialogInstance? MudDialogInstance { get; set; }

    #endregion

    #region Private Fields, Properties

    private string _note = string.Empty;

    #endregion

    #region Lifecycle Methods

    protected override async Task OnInitializedAsync()
    {
        if (MudDialogInstance is not null)
        {
            await MudDialogInstance.SetOptionsAsync(CreateDialogOptions());
        }
    }

    protected override void OnParametersSet()
    {
        ArgumentException.ThrowIfNullOrWhiteSpace(HabitName);
    }

    #endregion

    #region Event Handlers

    private void Cancel()
    {
        MudDialogInstance?.Cancel();
    }

    private void ConfirmCheckin()
    {
        MudDialogInstance?.Close(DialogResult.Ok(_note));
    }

    private void HandleUseCameraClick()
    {
    }

    private void HandleChoosePhotoClick()
    {
    }

    #endregion

    #region Private Helper Methods

    private static DialogOptions CreateDialogOptions()
    {
        return new DialogOptions
        {
            BackdropClick = false,
            CloseButton = true,
            CloseOnEscapeKey = true,
            FullWidth = true,
            MaxWidth = MaxWidth.ExtraSmall
        };
    }

    #endregion

    #region CSS Style Properties

    private const string CaptionTextStyle = "color: var(--mud-palette-text-secondary);";

    private const string SupportingTextStyle = "color: var(--mud-palette-text-secondary);";

    private const string ProofActionButtonStyle = "flex: 1 1 0;";

    private const string EmptyPreviewPanelStyle = "border: 1px solid var(--mud-palette-lines-default); background-color: var(--mud-palette-surface);";

    private const string EmptyPreviewContentStyle = "min-height: 120px;";

    private const string EmptyPreviewIconStyle = "color: var(--mud-palette-text-secondary);";

    #endregion

    #region Text, Label Properties

    private string DialogTitleText => $"Check in '{HabitName}'";

    private const string DialogMessageText = "Add an optional note or picture proof for today's check-in.";

    private const string NoteLabel = "Note (optional)";

    private const string NotePlaceholder = "Optional note";

    private const string NoteHelperText = "Plain text only";

    private const string CancelButtonText = "Cancel";

    private const string ConfirmButtonText = "Save check-in";

    private const string ProofSectionLabel = "Picture proof (optional)";

    private const string ProofSectionCaption = "One picture max for this check-in.";

    private const string UseCameraButtonText = "Use camera";

    private const string ChoosePhotoButtonText = "Choose photo";

    private const string EmptyPreviewText = "No picture selected";

    private const string UseCameraIcon = Icons.Material.Filled.PhotoCamera;

    private const string ChoosePhotoIcon = Icons.Material.Filled.PhotoLibrary;

    private const string EmptyPreviewIcon = Icons.Material.Filled.Image;

    private string NoteCounterText => $"{_note.Length} / {CoreConstants.CheckinNotesMaxLength}";

    #endregion

}
