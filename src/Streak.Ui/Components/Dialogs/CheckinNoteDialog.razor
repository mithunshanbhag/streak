<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6"
                 Class="mb-2">
            @DialogTitleText
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.body2">
                @DialogMessageText
            </MudText>

            <MudTextField T="string"
                          Margin="Margin.Dense"
                          ShrinkLabel="true"
                          Clearable="true"
                          Immediate="true"
                          @bind-Value="_note"
                          Label="@NoteLabel"
                          Placeholder="@NotePlaceholder"
                          MaxLength="@CoreConstants.CheckinNotesMaxLength"
                          Counter="@CoreConstants.CheckinNotesMaxLength"/>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text"
                   OnClick="Cancel">
            @CancelButtonText
        </MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="ConfirmCheckin">
            @ConfirmButtonText
        </MudButton>
    </DialogActions>
</MudDialog>

@code
{

    #region Parameters

    [Parameter] [EditorRequired] public string HabitName { get; set; } = string.Empty;

    [CascadingParameter] private IMudDialogInstance? MudDialogInstance { get; set; }

    #endregion

    #region Private Fields, Properties

    private string _note = string.Empty;

    #endregion

    #region Lifecycle Methods

    protected override async Task OnInitializedAsync()
    {
        if (MudDialogInstance is not null)
        {
            await MudDialogInstance.SetOptionsAsync(CreateDialogOptions());
        }
    }

    protected override void OnParametersSet()
    {
        ArgumentException.ThrowIfNullOrWhiteSpace(HabitName);
    }

    #endregion

    #region Event Handlers

    private void Cancel()
    {
        MudDialogInstance?.Cancel();
    }

    private void ConfirmCheckin()
    {
        MudDialogInstance?.Close(DialogResult.Ok(_note));
    }

    #endregion

    #region Private Helper Methods

    private static DialogOptions CreateDialogOptions()
    {
        return new DialogOptions
        {
            BackdropClick = false,
            CloseButton = true,
            CloseOnEscapeKey = true,
            FullWidth = true,
            MaxWidth = MaxWidth.ExtraSmall
        };
    }

    #endregion

    #region Text, Label Properties

    private string DialogTitleText => $"Check in '{HabitName}'";

    private const string DialogMessageText = "Add an optional note for today's check-in.";

    private const string NoteLabel = "Note (optional)";

    private const string NotePlaceholder = "Optional note";

    private const string CancelButtonText = "Cancel";

    private const string ConfirmButtonText = "Checkin";

    #endregion

}
