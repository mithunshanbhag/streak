@inject IHabitService HabitService
@inject NavigationManager NavigationManager

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6"
                 Class="mb-2">
            New habit
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @bind-IsValid="_isFormValid"
                 Model="@_newHabitInputModel">
            <MudStack Spacing="3">
                <MudTextField T="string"
                              Margin="Margin.Dense"
                              ShrinkLabel="true"
                              Clearable="true"
                              Immediate="true"
                              DebounceInterval="200"
                              @bind-Value="@_newHabitInputModel.Name"
                              For="@(() => _newHabitInputModel.Name)"
                              Label="Name"
                              Required="true"
                              Validation="@((string _) => ValidateNewHabitNameAsync())"
                              MaxLength="@CoreConstants.HabitNameMaxLength"
                              Counter="@CoreConstants.HabitNameMaxLength"/>
                <MudTextField T="string"
                              Margin="Margin.Dense"
                              ShrinkLabel="true"
                              Clearable="true"
                              Immediate="true"
                              DebounceInterval="200"
                              @bind-Value="@_newHabitInputModel.Emoji"
                              Placeholder="🙂"
                              For="@(() => _newHabitInputModel.Emoji!)"
                              Label="Emoji (optional)"
                              Validation="@((string _) => ValidateNewHabitEmoji())"/>

            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="@(_busyIndicator || !_isFormValid)"
                   OnClick="CreateNewHabitAsync">
            SAVE
            @if (_busyIndicator)
            {
                <MudProgressCircular Indeterminate="true"
                                     Size="Size.Small"
                                     Color="Color.Inherit"
                                     Class="ml-4"/>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code
{

    private bool _isFormValid;

    private readonly NewHabitInputModel _newHabitInputModel = new();

    private bool _busyIndicator;

    [CascadingParameter] private IMudDialogInstance? MudDialogInstance { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (MudDialogInstance is not null)
        {
            await MudDialogInstance.SetOptionsAsync(new DialogOptions
            {
                CloseButton = true,
                BackdropClick = false,
                CloseOnEscapeKey = true,
                FullWidth = true,
                MaxWidth = MaxWidth.Small
            });
        }
    }

    #region Private Helper Methods

    private async Task CreateNewHabitAsync()
    {
        await Task.CompletedTask; // Simulate async work (e.g., API call)

        try
        {
            _busyIndicator = true;

            var createdHabit = await HabitService.CreateAsync(new Habit
            {
                Id = 0, // Id will be set by the service/database
                Name = _newHabitInputModel.Name,
                Emoji = _newHabitInputModel.Emoji
            });

            await InvokeAsync(() =>
            {
                // Close the dialog with a success result
                MudDialogInstance?.Close(DialogResult.Ok(createdHabit));

                // Note: force load, else the newly created SKU will not be displayed
                NavigationManager.NavigateTo(RouteConstants.Home, true);
            });
        }
        finally
        {
            _busyIndicator = false;
        }
    }

    private async Task<string?> ValidateNewHabitNameAsync()
    {
        if (string.IsNullOrWhiteSpace(_newHabitInputModel.Name)) return "A valid name is required.";

        if (_newHabitInputModel.Name.Length < 3) return "Must be at least 3 characters long";

        // Check if this name already exists (case-insensitive)
        // @TODO: Update this later.
        var existingHabitNames = (await HabitService.GetAllAsync())
            .Select(x => x.Name)
            .ToArray();

        return existingHabitNames.Any(existingName => string.Equals(existingName, _newHabitInputModel.Name, StringComparison.OrdinalIgnoreCase))
            ? "A habit with this name already exists."
            : null; // i.e. valid
    }

    // @TODO: Update this later.
    private string? ValidateNewHabitEmoji()
    {
        if (string.IsNullOrWhiteSpace(_newHabitInputModel.Emoji)) return null; // Optional field

        if (!EmojiValidationHelper.IsEmptyOrSingleEmoji(_newHabitInputModel.Emoji))
            return "Emoji must be a single emoji.";

        return null; // i.e. valid
    }

    #endregion

}
