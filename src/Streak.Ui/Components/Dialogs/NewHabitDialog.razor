@inject IHabitService HabitService
@inject NavigationManager NavigationManager

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6"
                 Class="mb-2">
            @DialogTitleText
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @bind-IsValid="_isFormValid"
                 Model="@_newHabitInputModel">
            <MudStack Spacing="3">
                <MudTextField T="string"
                              Margin="Margin.Dense"
                              ShrinkLabel="true"
                              Clearable="true"
                              Immediate="true"
                              DebounceInterval="200"
                              @bind-Value="@_newHabitInputModel.Name"
                              For="@(() => _newHabitInputModel.Name)"
                              Label="@HabitNameLabel"
                              Required="true"
                              Validation="@((string _) => ValidateNewHabitNameAsync())"
                              MaxLength="@CoreConstants.HabitNameMaxLength"
                              Counter="@CoreConstants.HabitNameMaxLength"/>
                <MudTextField T="string"
                              Margin="Margin.Dense"
                              ShrinkLabel="true"
                              Clearable="true"
                              Immediate="true"
                              DebounceInterval="200"
                              @bind-Value="@_newHabitInputModel.Emoji"
                              Placeholder="@HabitEmojiPlaceholder"
                              For="@(() => _newHabitInputModel.Emoji!)"
                              Label="@HabitEmojiLabel"
                              Validation="@((string _) => ValidateNewHabitEmoji())"/>

            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="@(_busyIndicator || !_isFormValid)"
                   OnClick="CreateNewHabitAsync">
            @SaveButtonText
            @if (_busyIndicator)
            {
                <MudProgressCircular Indeterminate="true"
                                     Size="Size.Small"
                                     Color="Color.Inherit"
                                     Class="ml-4"/>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code
{

    #region Parameters

    [CascadingParameter] private IMudDialogInstance? MudDialogInstance { get; set; }

    #endregion

    #region Private Fields, Properties

    private bool _isFormValid;

    private readonly NewHabitInputModel _newHabitInputModel = new();

    private bool _busyIndicator;

    #endregion

    #region Lifecycle Methods

    protected override async Task OnInitializedAsync()
    {
        if (MudDialogInstance is not null)
        {
            await MudDialogInstance.SetOptionsAsync(CreateDialogOptions());
        }
    }

    #endregion

    #region Event Handlers

    private async Task CreateNewHabitAsync()
    {
        try
        {
            _busyIndicator = true;

            var createdHabit = await HabitService.CreateAsync(CreateHabit());

            await InvokeAsync(() =>
            {
                MudDialogInstance?.Close(DialogResult.Ok(createdHabit));
                NavigationManager.NavigateTo(RouteConstants.Home, true);
            });
        }
        finally
        {
            _busyIndicator = false;
        }
    }

    #endregion

    #region Private Helper Methods

    private async Task<string?> ValidateNewHabitNameAsync()
    {
        if (string.IsNullOrWhiteSpace(_newHabitInputModel.Name)) return ValidNameRequiredText;

        if (_newHabitInputModel.Name.Length < CoreConstants.HabitNameMinLength) return HabitNameTooShortText;

        var existingHabitNames = (await HabitService.GetAllAsync())
            .Select(x => x.Name)
            .ToArray();

        return existingHabitNames.Any(existingName => string.Equals(existingName, _newHabitInputModel.Name, StringComparison.OrdinalIgnoreCase))
            ? DuplicateHabitNameText
            : null;
    }

    private string? ValidateNewHabitEmoji()
    {
        if (string.IsNullOrWhiteSpace(_newHabitInputModel.Emoji)) return null;

        if (!EmojiValidationHelper.IsEmptyOrSingleEmoji(_newHabitInputModel.Emoji))
            return InvalidEmojiText;

        return null;
    }

    private static DialogOptions CreateDialogOptions()
    {
        return new DialogOptions
        {
            CloseButton = true,
            BackdropClick = false,
            CloseOnEscapeKey = true,
            FullWidth = true,
            MaxWidth = MaxWidth.Small
        };
    }

    private Habit CreateHabit()
    {
        return new Habit
        {
            Id = 0,
            Name = _newHabitInputModel.Name,
            Emoji = _newHabitInputModel.Emoji
        };
    }

    #endregion

    #region Text, Label Properties

    private const string DialogTitleText = "New habit";

    private const string HabitNameLabel = "Name";

    private const string HabitEmojiLabel = "Emoji (optional)";

    private const string HabitEmojiPlaceholder = "🙂";

    private const string SaveButtonText = "SAVE";

    private const string ValidNameRequiredText = "A valid name is required.";

    private static string HabitNameTooShortText => $"Must be at least {CoreConstants.HabitNameMinLength} characters long";

    private const string DuplicateHabitNameText = "A habit with this name already exists.";

    private const string InvalidEmojiText = "Emoji must be a single emoji.";

    #endregion

}