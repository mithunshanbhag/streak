<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6"
                 Class="mb-2">
            @DialogTitleText
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudStack Row="true"
                      AlignItems="AlignItems.Center"
                      Spacing="2">
                <MudPaper Elevation="0"
                          Class="d-inline-flex pa-2"
                          Style="@WarningIconContainerStyle">
                    <MudIcon Icon="@WarningIcon"
                             Color="Color.Warning"
                             Size="Size.Medium"/>
                </MudPaper>
                <MudText Typo="Typo.body2">
                    @DialogMessageText
                </MudText>
            </MudStack>

            <MudPaper Elevation="0"
                      Class="pa-3 rounded-lg"
                      Style="@ImpactPanelStyle">
                <MudStack Spacing="1">
                    <MudStack Row="true"
                              AlignItems="AlignItems.Center"
                              Spacing="1">
                        <MudIcon Icon="@SavedNoteIcon"
                                 Size="Size.Small"/>
                        <MudText Typo="Typo.caption">
                            @SavedNoteImpactText
                        </MudText>
                    </MudStack>
                    <MudStack Row="true"
                              AlignItems="AlignItems.Center"
                              Spacing="1">
                        <MudIcon Icon="@SavedPictureProofIcon"
                                 Size="Size.Small"/>
                        <MudText Typo="Typo.caption">
                            @SavedPictureProofImpactText
                        </MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text"
                   OnClick="Cancel">
            @CancelButtonText
        </MudButton>
        <MudButton Color="Color.Error"
                   Variant="Variant.Filled"
                   OnClick="ConfirmRemove">
            @ConfirmButtonText
        </MudButton>
    </DialogActions>
</MudDialog>

@code
{

    #region Parameters

    [Parameter] [EditorRequired] public string HabitName { get; set; } = string.Empty;

    [CascadingParameter] private IMudDialogInstance? MudDialogInstance { get; set; }

    #endregion

    #region Lifecycle Methods

    protected override async Task OnInitializedAsync()
    {
        if (MudDialogInstance is not null)
        {
            await MudDialogInstance.SetOptionsAsync(CreateDialogOptions());
        }
    }

    protected override void OnParametersSet()
    {
        ArgumentException.ThrowIfNullOrWhiteSpace(HabitName);
    }

    #endregion

    #region Event Handlers

    private void ConfirmRemove()
    {
        MudDialogInstance?.Close(DialogResult.Ok(true));
    }

    private void Cancel()
    {
        MudDialogInstance?.Cancel();
    }

    #endregion

    #region Private Helper Methods

    private static DialogOptions CreateDialogOptions()
    {
        return new DialogOptions
        {
            BackdropClick = false,
            CloseButton = true,
            CloseOnEscapeKey = true,
            FullWidth = true,
            MaxWidth = MaxWidth.ExtraSmall
        };
    }

    #endregion

    #region CSS Style Properties

    private const string WarningIconContainerStyle = "align-self: flex-start; border-radius: 999px; background-color: var(--mud-palette-warning-hover);";

    private const string ImpactPanelStyle = "background-color: var(--mud-palette-surface); border: 1px solid var(--mud-palette-lines-default);";

    #endregion

    #region Text, Label Properties

    private string DialogTitleText => $"Remove '{HabitName}' check-in?";

    private const string DialogMessageText = "This will remove today's check-in and also remove any saved note and picture-proof details from the app's record.";

    private const string CancelButtonText = "Keep check-in";

    private const string ConfirmButtonText = "Remove check-in";

    private const string SavedNoteImpactText = "Saved note";

    private const string SavedPictureProofImpactText = "Picture proof";

    private const string WarningIcon = Icons.Material.Filled.Warning;

    private const string SavedNoteIcon = Icons.Material.Filled.Notes;

    private const string SavedPictureProofIcon = Icons.Material.Filled.Image;

    #endregion

}
