@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager NavigationManager

<MudThemeProvider Theme="@AppTheme"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<CascadingValue Value="@_appBarTitleState"
                IsFixed="true">
    <MudLayout>
        <MudAppBar Color="Color.Primary"
                   Dense="true"
                   Elevation="1">
            @if (_isHomePage)
            {
                <MudTooltip Text="@HomeLogoTooltipText">
                    <MudText Typo="Typo.h5">
                        @AppTitleText
                    </MudText>
                </MudTooltip>
                <MudSpacer/>
                <MudTooltip Text="@SettingsTooltipText">
                    <MudIconButton Class="mr-4"
                                   Href="@RouteConstants.Settings"
                                   Icon="@Icons.Material.Filled.Settings"
                                   Color="Color.Inherit"
                                   aria-label="@SettingsAriaLabel"/>
                </MudTooltip>
                <MudTooltip Text="@GitHubTooltipText"
                            Placement="Placement.Left">
                    <MudIconButton Class="mr-4"
                                    Icon="@Icons.Custom.Brands.GitHub"
                                    Color="Color.Inherit"
                                    OnClick="OpenGitHubRepositoryAsync"
                                    aria-label="@GitHubAriaLabel"/>
                </MudTooltip>
            }
            else
            {
                <MudTooltip Text="@BackTooltipText">
                    <MudIconButton Class="mr-2"
                                   Icon="@Icons.Material.Filled.ArrowBack"
                                   Color="Color.Inherit"
                                   Href="@RouteConstants.Home"
                                   aria-label="@BackAriaLabel"/>
                </MudTooltip>

                @if (_appBarTitleState.HasTitle)
                {
                    <MudStack Row="true"
                              AlignItems="AlignItems.Center"
                              Spacing="1"
                              Class="app-bar-secondary-title"
                              Style="@SecondaryAppBarTitleContainerStyle">
                        @if (_appBarTitleState.HasLeadingEmoji)
                        {
                            <MudText Typo="Typo.h6"
                                     Class="app-bar-title-emoji"
                                     Style="@SecondaryAppBarTitleEmojiStyle">
                                @_appBarTitleState.LeadingEmoji
                            </MudText>
                        }

                        <MudText Typo="Typo.h6"
                                 Class="app-bar-title-text"
                                 Style="@SecondaryAppBarTitleTextStyle">
                            @_appBarTitleState.TitleText
                        </MudText>
                    </MudStack>
                }
                else
                {
                    <MudSpacer/>
                }
            }
        </MudAppBar>

        <MudMainContent>
            <main role="main">
                @Body
            </main>
        </MudMainContent>

        @if (!_isSettingsPage)
        {
            <MudScrollToTop>
                <MudTooltip Text="@ScrollToTopTooltipText">
                    <MudFab Color="Color.Primary"
                            IconSize="Size.Large"
                            Size="Size.Large"
                            StartIcon="@Icons.Material.Filled.ArrowUpward"
                            aria-label="@ScrollToTopAriaLabel"/>
                </MudTooltip>
            </MudScrollToTop>
        }

    </MudLayout>
</CascadingValue>

@code
{

    #region Private Fields, Properties

    private bool _isHomePage;

    private bool _isSettingsPage;

    private readonly AppBarTitleState _appBarTitleState = new();

    private static readonly string[] AppFontFamily =
    [
        "Roboto",
        "system-ui",
        "\"Segoe UI\"",
        "Arial",
        "sans-serif"
    ];

    private static readonly MudTheme AppTheme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#6200EE",
            Secondary = "#03DAC6",
            Success = "#4CAF50",
            Surface = "#FFFFFF",
            TextPrimary = "#000000",
            TextSecondary = "#757575"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#BB86FC",
            Secondary = "#03DAC6",
            Success = "#81C784",
            Surface = "#121212",
            TextPrimary = "#FFFFFF",
            TextSecondary = "#757575"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = AppFontFamily
            }
        }
    };

    #endregion

    #region Lifecycle Methods

    protected override void OnInitialized()
    {
        UpdateRouteState(NavigationManager.Uri);
        _appBarTitleState.Changed += HandleAppBarTitleChanged;
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    #endregion

    #region Event Handlers

    public void Dispose()
    {
        _appBarTitleState.Changed -= HandleAppBarTitleChanged;
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }

    private void HandleAppBarTitleChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateRouteState(e.Location);

        // @TODO: Check if this line is really needed.
        _ = InvokeAsync(StateHasChanged);
    }

    private static async Task OpenGitHubRepositoryAsync()
    {
        await Browser.Default.OpenAsync(UrlConstants.GitHubRepo, BrowserLaunchMode.External);
    }

    #endregion

    #region Private Helper Methods

    private void UpdateRouteState(string uri)
    {
        var relativePath = NavigationManager.ToBaseRelativePath(uri);

        var separatorIndex = relativePath.IndexOfAny(['?', '#']);

        var normalizedPath = separatorIndex >= 0
            ? relativePath[..separatorIndex]
            : relativePath;

        var normalizedPathTrimmed = normalizedPath.Trim('/');

        _isHomePage = string.IsNullOrEmpty(normalizedPathTrimmed);
        _isSettingsPage = string.Equals(normalizedPathTrimmed, RouteConstants.Settings.Trim('/'), StringComparison.Ordinal);
    }

    #endregion

    #region CSS Style Properties

    private const string SecondaryAppBarTitleContainerStyle = "min-width: 0; flex: 1 1 auto;";

    private const string SecondaryAppBarTitleEmojiStyle = "flex-shrink: 0;";

    private const string SecondaryAppBarTitleTextStyle = "min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;";

    #endregion

    #region Text, Label Properties

    private const string AppTitleText = "Streak";

    private const string HomeLogoTooltipText = "Let your habits compound";

    private const string SettingsTooltipText = "Settings";

    private const string SettingsAriaLabel = "Settings";

    private const string GitHubTooltipText = "View source code";

    private const string GitHubAriaLabel = "View source code on GitHub";

    private const string BackTooltipText = "Back to habits";

    private const string BackAriaLabel = "Back to habits";

    private const string ScrollToTopTooltipText = "Scroll to top";

    private const string ScrollToTopAriaLabel = "Scroll to top of page";

    #endregion

}
