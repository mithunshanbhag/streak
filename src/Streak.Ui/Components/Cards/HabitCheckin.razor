<MudPaper Elevation="1"
          Class="px-4 py-3 rounded-lg"
          Style="@CardStyle">
    <MudStack Row="true"
              AlignItems="AlignItems.Center"
              Justify="Justify.SpaceBetween"
              Wrap="Wrap.NoWrap"
              Spacing="2">
        <MudStack Row="true"
                  AlignItems="AlignItems.Center"
                  Wrap="Wrap.NoWrap"
                  Spacing="2"
                  Style="min-width: 0; flex: 1;">
            <MudPaper Elevation="0"
                      Class="rounded-lg"
                      Style="width: 40px; height: 40px; background-color: var(--mud-palette-primary-hover);">
                <MudStack AlignItems="AlignItems.Center"
                          Justify="Justify.Center"
                          Style="width: 40px; height: 40px;">
                    @if (string.IsNullOrWhiteSpace(Habit.Emoji))
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Circle"
                                 Size="Size.Small"
                                 Color="Color.Primary"/>
                    }
                    else
                    {
                        <MudText Typo="Typo.h6">@Habit.Emoji</MudText>
                    }
                </MudStack>
            </MudPaper>

            <MudStack Spacing="0"
                      Style="min-width: 0; flex: 1;">
                <MudText Typo="Typo.body1"
                         Style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                    @Habit.Name
                </MudText>
                <MudText Typo="Typo.body2"
                         Style="@StreakTextStyle">
                    @StreakText
                </MudText>
            </MudStack>
        </MudStack>

        <MudIconButton Icon="@ToggleIcon"
                       Color="@ToggleIconColor"
                       Size="Size.Large"
                       Style="@ToggleIconStyle"
                       aria-label="@ToggleAriaLabel"/>
    </MudStack>
</MudPaper>

@code {

    [Parameter]
    public required Habit Habit { get; set; }

    [Parameter]
    public required int CurrentStreak { get; set; }

    [Parameter]
    public required bool IsCheckedToday { get; set; }

    private string CardStyle => IsCheckedToday
        ? "width: 100%; border-left: 4px solid var(--mud-palette-success);"
        : "width: 100%; border-left: 4px solid transparent;";

    private string ToggleIcon => IsCheckedToday
        ? Icons.Material.Filled.CheckCircle
        : Icons.Material.Filled.RadioButtonUnchecked;

    private Color ToggleIconColor => IsCheckedToday
        ? Color.Success
        : Color.Inherit;

    private string? ToggleIconStyle => IsCheckedToday
        ? null
        : "color: var(--mud-palette-text-secondary);";

    private string ToggleAriaLabel => IsCheckedToday
        ? $"Habit '{Habit.Name}' is checked in for today."
        : $"Habit '{Habit.Name}' is not checked in for today.";

    private string StreakTextStyle => CurrentStreak switch
    {
        >= 7 => "color: var(--mud-palette-warning);",
        >= 1 => "color: var(--mud-palette-info);",
        _ => "color: var(--mud-palette-text-secondary);"
    };

    private string StreakText => CurrentStreak switch
    {
        >= 7 => $"🔥 {CurrentStreak} day streak",
        >= 1 => $"😎 {CurrentStreak} day streak",
        _ => "0 streak"
    };

}
