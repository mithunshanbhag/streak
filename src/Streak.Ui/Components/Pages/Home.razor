@page "/"
@using Streak.Ui.Components.Cards
@inject IHabitService HabitService
@inject IDialogService DialogService

<PageTitle>Streak</PageTitle>

@* Page has not been initialized yet. *@
@if (_loadingData)
{
    <MudAlert ContentAlignment="HorizontalAlignment.Center"
              Severity="Severity.Info">
        Loading Data...
    </MudAlert>
}
@* Page initialized *@
else
{
    if (_habitCheckins.Count == 0)
    {
        <MudContainer MaxWidth="MaxWidth.Small"
                      Class="pa-4">
            <MudStack Style="min-height: 100vh"
                      Justify="Justify.Center"
                      AlignItems="AlignItems.Center">
                <MudFab Color="Color.Tertiary"
                        StartIcon="@Icons.Material.Filled.Add"
                        Label="New Habit"
                        Size="Size.Large"
                        OnClick="OpenQuickAddDialogAsync"/>
            </MudStack>
        </MudContainer>
    }
    else
    {
        <MudContainer MaxWidth="MaxWidth.Small"
                      Class="pa-4">
            <MudStack Spacing="3">
                @foreach (var habitCheckin in _habitCheckins)
                {
                    <HabitCheckin Habit="@habitCheckin.Habit"
                                  CurrentStreak="@habitCheckin.CurrentStreak"
                                  IsCheckedToday="@habitCheckin.IsCheckedToday"/>
                }

                @if (_habitCheckins.Count < CoreConstants.MaxHabitCount)
                {
                    <MudDivider Class="my-1"/>
                    <MudFab Color="Color.Tertiary"
                            StartIcon="@Icons.Material.Filled.Add"
                            Label="New Habit"
                            Size="Size.Large"
                            OnClick="OpenQuickAddDialogAsync"/>
                }
            </MudStack>
        </MudContainer>
    }
}

@code
{
    private IReadOnlyList<HabitCheckinDisplayItem> _habitCheckins = [];

    private bool _loadingData;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    #region Private Helper Methods

    private async Task LoadDataAsync()
    {
        _loadingData = true;

        var habits = await HabitService.GetAllAsync();
        _habitCheckins = habits
            .Select(habit => new HabitCheckinDisplayItem(habit, 0, false))
            .ToArray();

        _loadingData = false;
    }

    private async Task OpenQuickAddDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<NewHabitDialog>();

        var dialogResult = await dialog.Result;

        if (dialogResult is null ||
            dialogResult.Canceled ||
            dialogResult.Data is not CreateHabitDialogResultModel)
        {
            return;
        }

        await LoadDataAsync();
    }

    private sealed record HabitCheckinDisplayItem(
        Habit Habit,
        int CurrentStreak,
        bool IsCheckedToday);

    #endregion

}
