@page "/"
@using Streak.Ui.Components.Cards
@inject IHabitService HabitService
@inject ICheckinService CheckinService
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<PageTitle>Streak</PageTitle>

@* Page has not been initialized yet. *@
@if (_loadingData)
{
    <MudAlert ContentAlignment="HorizontalAlignment.Center"
              Severity="Severity.Info">
        Loading Data...
    </MudAlert>
}
@* Page initialized *@
else
{
    if (_habitCheckins.Count == 0)
    {
        <MudContainer MaxWidth="MaxWidth.Small"
                      Class="pa-4">
            <MudStack Style="min-height: 100vh"
                      Justify="Justify.Center"
                      AlignItems="AlignItems.Center">
                <MudFab Color="Color.Tertiary"
                        StartIcon="@Icons.Material.Filled.Add"
                        Label="New Habit"
                        Size="Size.Large"
                        OnClick="OpenQuickAddDialogAsync"/>
            </MudStack>
        </MudContainer>
    }
    else
    {
        <MudContainer MaxWidth="MaxWidth.Small"
                      Class="pa-4">
            <MudStack Spacing="3">
                @foreach (var habitCheckin in _habitCheckins)
                {
                    <HabitCheckin ViewModel="@habitCheckin"
                                  OnCardClick="OpenHabitDetailsAsync"/>
                }

                @if (_habitCheckins.Count < CoreConstants.MaxHabitCount)
                {
                    <MudDivider Class="my-1"/>
                    <MudFab Color="Color.Tertiary"
                            StartIcon="@Icons.Material.Filled.Add"
                            Label="New Habit"
                            Size="Size.Large"
                            OnClick="OpenQuickAddDialogAsync"/>
                }
            </MudStack>
        </MudContainer>
    }
}

@code
{
    private IReadOnlyList<HabitCheckinCardViewModel> _habitCheckins = [];

    private bool _loadingData;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    #region Private Helper Methods

    private async Task LoadDataAsync()
    {
        _loadingData = true;

        var habits = await HabitService.GetAllAsync();
        var todayDate = DateOnly
            .FromDateTime(DateTime.UtcNow)
            .ToString(CoreConstants.CheckinDateFormat, global::System.Globalization.CultureInfo.InvariantCulture);

        var habitCheckinTasks = habits.Select(habit => CreateHabitCheckinCardViewModelAsync(habit, todayDate));

        _habitCheckins = await Task.WhenAll(habitCheckinTasks);

        _loadingData = false;
    }

    private async Task<HabitCheckinCardViewModel> CreateHabitCheckinCardViewModelAsync(Habit habit, string todayDate)
    {
        var currentStreakTask = CheckinService.GetCurrentStreakAsync(habit.Name);
        var todayCheckinTask = CheckinService.GetByHabitNameAndDateAsync(habit.Name, todayDate);

        await Task.WhenAll(currentStreakTask, todayCheckinTask);

        var todayCheckin = await todayCheckinTask;

        return new HabitCheckinCardViewModel
        {
            HabitId = habit.Id,
            HabitName = habit.Name,
            HabitEmoji = habit.Emoji,
            CurrentStreak = await currentStreakTask,
            IsDoneForToday = todayCheckin is not null
        };
    }

    private async Task OpenQuickAddDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<NewHabitDialog>();

        var dialogResult = await dialog.Result;

        if (dialogResult is null ||
            dialogResult.Canceled ||
            dialogResult.Data is not CreateHabitDialogResultModel)
        {
            return;
        }

        await LoadDataAsync();
    }

    private Task OpenHabitDetailsAsync(int habitId)
    {
        NavigationManager.NavigateTo(RouteConstants.GetHabitDetails(habitId));
        return Task.CompletedTask;
    }

    #endregion

}
