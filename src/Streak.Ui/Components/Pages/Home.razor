@page "/"
@using Streak.Core.Models.ViewModels.ResultModels
@inject IHabitService HabitService
@inject IDialogService DialogService

<PageTitle>Streak</PageTitle>

<PageHeader BreadcrumbItems="@(
                             [
                                 new BreadcrumbItem("Home", "#", true)
                             ])"/>

@* Page has not been initialized yet. *@
@if (_loadingData)
{
    <MudAlert ContentAlignment="HorizontalAlignment.Center"
              Severity="Severity.Info">
        Loading Data...
    </MudAlert>
}
@* Page initialized *@
else
{
    if (_habits.Count == 0)
    {
        <MudStack Style="min-height: 100vh"
                  Justify="Justify.Center"
                  AlignItems="AlignItems.Center">
            <MudFab Color="Color.Tertiary"
                    StartIcon="@Icons.Material.Filled.Add"
                    Label="New Habit"
                    Size="Size.Large"
                    OnClick="OpenQuickAddDialogAsync"/>
        </MudStack>
    }
    else
    {
        <MudStack Spacing="2">
            @foreach (var habit in _habits)
            {
                <MudText Typo="Typo.h6">
                    @habit.Name
                </MudText>
            }

            @if (_habits.Count < CoreConstants.MaxHabitCount)
            {
                <MudDivider Class="my-2"/>
                <MudButton StartIcon="@Icons.Material.Filled.Add"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           FullWidth="true"
                           OnClick="OpenQuickAddDialogAsync">
                    New Habit
                </MudButton>
            }
        </MudStack>
    }
}

@code
{
    private IReadOnlyList<Habit> _habits = [];

    private bool _loadingData;
    private bool _isQuickAddOpen;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync(bool showLoadingIndicator = true)
    {
        if (showLoadingIndicator)
        {
            _loadingData = true;
        }

        try
        {
            _habits = await HabitService.GetAllAsync();
        }
        finally
        {
            if (showLoadingIndicator)
            {
                _loadingData = false;
            }
        }
    }

    private async Task OpenQuickAddDialogAsync()
    {
        if (_isQuickAddOpen || _habits.Count >= CoreConstants.MaxHabitCount)
        {
            return;
        }

        _isQuickAddOpen = true;

        try
        {
            var dialog = await DialogService.ShowAsync<CreateHabitDialog>();

            var dialogResult = await dialog.Result;

            if (dialogResult is null ||
                dialogResult.Canceled ||
                dialogResult.Data is not CreateHabitDialogResultModel)
            {
                return;
            }

            await LoadDataAsync(false);
        }
        finally
        {
            _isQuickAddOpen = false;
        }
    }
}