@page "/"
@inject ICheckinService CheckinService
@inject IDialogService DialogService

<PageTitle>Streak</PageTitle>

@* Page has not been initialized yet. *@
@if (_loadingData)
{
    <MudStack Style="@LoadingStateStyle"
              Justify="Justify.Center"
              AlignItems="AlignItems.Center">
        <MudAlert ContentAlignment="HorizontalAlignment.Center"
                  Severity="Severity.Info">
            @LoadingDataText
        </MudAlert>
    </MudStack>
}
@* Page initialized *@
else
{
    if (_habitCheckins.Count == 0)
    {
        <MudContainer MaxWidth="MaxWidth.Small"
                      Class="pa - 4">
            <MudStack Style="@EmptyStateStyle"
                      Justify="Justify.Center"
                      AlignItems="AlignItems.Center">
                <MudFab Color="Color.Tertiary"
                        StartIcon="@Icons.Material.Filled.Add"
                        Label="@NewHabitButtonLabel"
                        Size="Size.Large"
                        OnClick="OpenQuickAddDialogAsync"/>
            </MudStack>
        </MudContainer>
    }
    else
    {
        <MudContainer MaxWidth="MaxWidth.ExtraSmall"
                      Class="pa-4">
            <MudStack Spacing="3">
                <MudPaper Elevation="0"
                          Class="px-3 py-1 rounded-pill"
                          Style="@DateBannerStyle">
                    <MudStack Row="true"
                              AlignItems="AlignItems.Center"
                              Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.Today"
                                 Size="Size.Small"/>
                        <MudText Typo="Typo.body2">
                            @DateBannerText
                        </MudText>
                    </MudStack>
                </MudPaper>

                @foreach (var habitCheckin in _habitCheckins)
                {
                    <HabitCheckin ViewModel="@habitCheckin"
                                  OnCheckinChanged="@(async isDone => await HandleCheckinChangedAsync(habitCheckin, isDone))"/>
                }

                @if (_habitCheckins.Count < CoreConstants.MaxHabitCount)
                {
                    <MudDivider Class="my-1"/>
                    <MudFab Color="Color.Tertiary"
                            StartIcon="@Icons.Material.Filled.Add"
                            Label="@NewHabitButtonLabel"
                            Size="Size.Large"
                            OnClick="OpenQuickAddDialogAsync"/>
                }
            </MudStack>
        </MudContainer>
    }
}

@code
{

    #region Private Fields, Properties

    private IReadOnlyList<HabitCheckinViewModel> _habitCheckins = [];

    private bool _loadingData;

    #endregion

    #region Lifecycle Methods

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    #endregion

    #region Event Handlers

    private async Task OpenQuickAddDialogAsync()
    {
        await DialogService.ShowAsync<NewHabitDialog>();
    }

    private async Task HandleCheckinChangedAsync(HabitCheckinViewModel viewModel, bool isDone)
    {
        ArgumentNullException.ThrowIfNull(viewModel);

        if (viewModel.IsDoneForToday == isDone)
            return;

        if (isDone)
        {
            var noteDialogResult = await ShowCheckinNoteDialogAsync(viewModel);
            if (!noteDialogResult.Submitted)
                return;

            await CheckinService.ToggleForTodayAsync(viewModel.HabitName, true, noteDialogResult.Note);
        }
        else
        {
            var isConfirmed = await ShowRemoveCheckinDialogAsync(viewModel);
            if (!isConfirmed)
                return;

            await CheckinService.ToggleForTodayAsync(viewModel.HabitName, false);
        }

        viewModel.Streak = await CheckinService.GetCurrentStreakAsync(viewModel.HabitName);
        viewModel.IsDoneForToday = isDone;
        await InvokeAsync(StateHasChanged);
    }

    #endregion

    #region Private Helper Methods

    private async Task LoadDataAsync()
    {
        _loadingData = true;

        _habitCheckins = await CheckinService.GetHomePageHabitCheckinsAsync();

        _loadingData = false;
    }

    private async Task<(bool Submitted, string? Note)> ShowCheckinNoteDialogAsync(HabitCheckinViewModel viewModel)
    {
        var dialog = await DialogService.ShowAsync<CheckinNoteDialog>(
            CheckinNoteDialogTitleText,
            CreateCheckinNoteDialogParameters(viewModel));

        var result = await dialog.Result;
        if (result is null || result.Canceled)
            return (false, null);

        if (result.Data is not null and not string)
            throw new InvalidOperationException("Check-in note dialog returned an unexpected result.");

        return (true, result.Data as string);
    }

    private async Task<bool> ShowRemoveCheckinDialogAsync(HabitCheckinViewModel viewModel)
    {
        var dialog = await DialogService.ShowAsync<RemoveCheckinDialog>(
            RemoveCheckinDialogTitleText,
            CreateRemoveCheckinDialogParameters(viewModel));

        var result = await dialog.Result;
        return result is not null && !result.Canceled;
    }

    private static DialogParameters<CheckinNoteDialog> CreateCheckinNoteDialogParameters(HabitCheckinViewModel viewModel)
    {
        return new DialogParameters<CheckinNoteDialog>
        {
            { x => x.HabitName, viewModel.HabitName }
        };
    }

    private static DialogParameters<RemoveCheckinDialog> CreateRemoveCheckinDialogParameters(HabitCheckinViewModel viewModel)
    {
        return new DialogParameters<RemoveCheckinDialog>
        {
            { x => x.HabitName, viewModel.HabitName }
        };
    }

    #endregion

    #region CSS Style Properties

    private const string LoadingStateStyle = "min-height: 80dvh";

    private const string EmptyStateStyle = "min-height: 100dvh";

    private const string DateBannerStyle = "align-self: center; background-color: var(--mud-palette-primary-hover); color: var(--mud-palette-primary);";

    #endregion

    #region Text, Label Properties

    private const string LoadingDataText = "Loading Data...";

    private const string NewHabitButtonLabel = "New Habit";

    private const string CheckinNoteDialogTitleText = "Check in";

    private const string RemoveCheckinDialogTitleText = "Remove check-in";

    private static string DateBannerText => DateDisplayHelper.FormatDateBanner(DateTime.Now);

    #endregion

}
