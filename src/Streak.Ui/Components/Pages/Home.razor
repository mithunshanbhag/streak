@page "/"
@inject IHabitService HabitService
@inject IDialogService DialogService

<PageTitle>Streak</PageTitle>

@* Page has not been initialized yet. *@
@if (_loadingData)
{
    <MudAlert ContentAlignment="HorizontalAlignment.Center"
              Severity="Severity.Info">
        Loading Data...
    </MudAlert>
}
@* Page initialized *@
else
{
    if (_habits.Count == 0)
    {
        <MudStack Style="min-height: 100vh"
                  Justify="Justify.Center"
                  AlignItems="AlignItems.Center">
            <MudFab Color="Color.Tertiary"
                    StartIcon="@Icons.Material.Filled.Add"
                    Label="New Habit"
                    Size="Size.Large"
                    OnClick="@(() => DialogService.ShowAsync<NewHabitDialog>())"/>
        </MudStack>
    }
    else
    {
        <MudStack Justify="Justify.Center"
                  AlignItems="AlignItems.Center"
                  Spacing="2">
            @foreach (var habit in _habits)
            {
                <MudText Typo="Typo.h6">
                    @habit.Name
                </MudText>
            }

            @if (_habits.Count < CoreConstants.MaxHabitCount)
            {
                <MudDivider Class="my-2"/>
                <MudFab Color="Color.Tertiary"
                        StartIcon="@Icons.Material.Filled.Add"
                        Label="New Habit"
                        Size="Size.Large"
                        OnClick="@(() => DialogService.ShowAsync<NewHabitDialog>())"/>
            }
        </MudStack>
    }
}

@code
{
    private IReadOnlyList<Habit> _habits = [];

    private bool _loadingData;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    #region Private Helper Methods

    private async Task LoadDataAsync()
    {
        _loadingData = true;

        _habits = await HabitService.GetAllAsync();

        _loadingData = false;
    }

    private async Task OpenQuickAddDialogAsync()
    {
        var dialog = await DialogService.ShowAsync<NewHabitDialog>();

        var dialogResult = await dialog.Result;

        if (dialogResult is null ||
            dialogResult.Canceled ||
            dialogResult.Data is not CreateHabitDialogResultModel)
        {
            return;
        }

        await LoadDataAsync();
    }

    #endregion

}