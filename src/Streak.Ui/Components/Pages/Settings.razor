@page "/settings"
@inject IAutomatedBackupConfigurationService AutomatedBackupConfigurationService
@inject IReminderConfigurationService ReminderConfigurationService
@inject IDatabaseExportService DatabaseExportService
@inject IDiagnosticsExportService DiagnosticsExportService
@inject IDatabaseShareService DatabaseShareService
@inject IDiagnosticsShareService DiagnosticsShareService
@inject IDatabaseImportFilePicker DatabaseImportFilePicker
@inject IDatabaseImportService DatabaseImportService
@inject IManualBackupCompletionNotifier ManualBackupCompletionNotifier
@inject IBackupNotificationPermissionService BackupNotificationPermissionService
@inject IReminderNotificationPermissionCoordinator ReminderNotificationPermissionCoordinator
@inject IAppVersionInfoService AppVersionInfoService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject ILogger<Settings> Logger

<PageTitle>@SettingsPageTitleText</PageTitle>
<AppBarTitleScope TitleText="@SettingsPageTitleText"/>

<MudContainer MaxWidth="MaxWidth.Small"
              Class="pa-4">
    <MudStack Spacing="3">
        @if (!string.IsNullOrWhiteSpace(SettingsMetadataBannerText))
        {
            <MudPaper Elevation="0"
                      Class="px-3 py-1 rounded-pill"
                      Style="@SettingsMetadataBannerStyle"
                      aria-label="@SettingsMetadataBannerAriaLabel">
                <MudStack Row="true"
                          AlignItems="AlignItems.Center"
                          Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.Info"
                             Size="Size.Small"/>
                    <MudText Typo="Typo.body2">
                        @SettingsMetadataBannerText
                    </MudText>
                </MudStack>
            </MudPaper>
        }

        @if (!string.IsNullOrWhiteSpace(_operationErrorMessage))
        {
            <MudAlert Severity="Severity.Error"
                      Dense="true">
                @_operationErrorMessage
            </MudAlert>
        }

        <MudPaper Elevation="1"
                  Class="pa-4 rounded-lg">
            <MudStack Spacing="3">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption"
                             Class="text-secondary">
                        @ReminderSectionEyebrowText
                    </MudText>

                    <MudText Typo="Typo.h6">
                        @ReminderHeaderText
                    </MudText>
                </MudStack>

                <MudPaper Elevation="0"
                          Class="pa-3 rounded-lg">
                    <MudStack Row="true"
                              Justify="Justify.SpaceBetween"
                              AlignItems="AlignItems.Center"
                              Spacing="3">
                        <MudText Typo="Typo.body1">
                            @ReminderToggleLabelText
                        </MudText>

                        <MudSwitch T="bool"
                                   Value="@_remindersEnabled"
                                   ValueChanged="ReminderEnabledChangedAsync"
                                   Disabled="@ReminderControlsDisabled"
                                   Color="Color.Primary"
                                   aria-label="@ReminderSwitchAriaLabel"/>
                    </MudStack>
                </MudPaper>

                @if (_remindersEnabled)
                {
                    <MudPaper Elevation="0"
                              Class="pa-3 rounded-lg">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.body2">
                                @ReminderTimeLabelText
                            </MudText>

                            <MudTimePicker Time="@_reminderTimeLocal"
                                           TimeChanged="ReminderTimeChangedAsync"
                                           Label="@ReminderTimeLabelText"
                                           AmPm="true"
                                           Variant="Variant.Outlined"
                                           Disabled="@ReminderControlsDisabled" />
                        </MudStack>
                    </MudPaper>
                }

                <MudText Typo="Typo.caption"
                         Class="text-secondary">
                    @ReminderHelperText
                </MudText>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="1"
                  Class="pa-4 rounded-lg">
            <MudStack Spacing="3">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption"
                             Class="text-secondary">
                        @SectionEyebrowText
                    </MudText>
                </MudStack>

                <MudStack Spacing="1">
                    <MudStack Row="true"
                              Spacing="1"
                              AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">
                            @AutomatedBackupsHeaderText
                        </MudText>

                        <MudTooltip Text="@AutomatedBackupsTooltipText"
                                    Placement="Placement.Top">
                            <MudIconButton Icon="@Icons.Material.Filled.Info"
                                            Color="Color.Default"
                                            Size="Size.Small"
                                            aria-label="@AutomatedBackupsTooltipAriaLabel"/>
                        </MudTooltip>
                    </MudStack>

                    <MudText Typo="Typo.body2"
                             Class="text-secondary">
                        @AutomatedBackupsDescriptionText
                    </MudText>
                </MudStack>

                <MudPaper Elevation="0"
                          Class="pa-3 rounded-lg">
                    <MudStack Row="true"
                              Justify="Justify.FlexEnd"
                              AlignItems="AlignItems.Center"
                              Spacing="0">
                        <MudSwitch T="bool"
                                   Value="@_automatedBackupsEnabled"
                                   ValueChanged="AutomatedBackupsEnabledChangedAsync"
                                   Disabled="@AutomatedBackupsToggleDisabled"
                                   Color="Color.Primary"
                                   aria-label="@AutomatedBackupsSwitchAriaLabel"/>
                    </MudStack>
                </MudPaper>

                <MudDivider/>

                <MudStack Spacing="1">
                    <MudStack Row="true"
                              Spacing="1"
                              AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">
                            @OneDriveBackupHeaderText
                        </MudText>

                        <MudTooltip Text="@OneDriveBackupTooltipText"
                                    Placement="Placement.Top">
                            <MudIconButton Icon="@Icons.Material.Filled.Info"
                                           Color="Color.Default"
                                           Size="Size.Small"
                                           aria-label="@OneDriveBackupTooltipAriaLabel"/>
                        </MudTooltip>
                    </MudStack>

                    <MudText Typo="Typo.body2"
                             Class="text-secondary">
                        @OneDriveBackupDescriptionText
                    </MudText>
                </MudStack>

                <MudPaper Elevation="0"
                          Class="pa-3 rounded-lg"
                          Style="@OneDriveProviderPanelStyle">
                    <MudStack Spacing="2">
                        <MudStack Row="true"
                                  Justify="Justify.SpaceBetween"
                                  AlignItems="AlignItems.Center"
                                  Spacing="2">
                            <MudStack Row="true"
                                      Spacing="1"
                                      AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Cloud"
                                         Color="Color.Primary"/>

                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body1">
                                        @OneDriveProviderNameText
                                    </MudText>

                                    <MudText Typo="Typo.caption"
                                             Class="text-secondary">
                                        @OneDriveProviderStateText
                                    </MudText>
                                </MudStack>
                            </MudStack>

                            <MudPaper Elevation="0"
                                      Class="px-2 py-1 rounded-pill"
                                      Style="@OneDriveStatusChipStyle">
                                <MudText Typo="Typo.caption">
                                    @OneDriveStatusChipText
                                </MudText>
                            </MudPaper>
                        </MudStack>

                        <MudText Typo="Typo.body2"
                                 Class="text-secondary">
                            @OneDriveProviderSupportText
                        </MudText>
                    </MudStack>
                </MudPaper>

                <MudPaper Elevation="0"
                          Class="pa-3 rounded-lg">
                    <MudStack Row="true"
                              Justify="Justify.SpaceBetween"
                              AlignItems="AlignItems.Center"
                              Spacing="3">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body1">
                                @CloudAutomatedBackupsLabelText
                            </MudText>

                            <MudText Typo="Typo.caption"
                                     Class="text-secondary">
                                @CloudAutomatedBackupsDescriptionText
                            </MudText>
                        </MudStack>

                        <MudSwitch T="bool"
                                   Value="@OneDriveCloudBackupEnabledPlaceholder"
                                   Disabled="@OneDriveBackupControlsDisabled"
                                   Color="Color.Primary"
                                   aria-label="@CloudAutomatedBackupsSwitchAriaLabel"/>
                    </MudStack>
                </MudPaper>

                <MudPaper Elevation="0"
                          Class="pa-3 rounded-lg">
                    <MudButton Color="Color.Primary"
                               Variant="Variant.Filled"
                               Disabled="@OneDriveBackupControlsDisabled"
                               StartIcon="@Icons.Material.Filled.CloudQueue"
                               aria-label="@ConnectOneDriveButtonAriaLabel">
                        @ConnectOneDriveButtonText
                    </MudButton>
                </MudPaper>

                <MudDivider/>

                <MudStack Spacing="1">
                    <MudStack Row="true"
                              Spacing="1"
                              AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">
                            @BackupHeaderText
                        </MudText>

                        <MudTooltip Text="@SupportNoteText"
                                    Placement="Placement.Top">
                            <MudIconButton Icon="@Icons.Material.Filled.Info"
                                           Color="Color.Default"
                                           Size="Size.Small"
                                           aria-label="@SupportTooltipAriaLabel"/>
                        </MudTooltip>
                    </MudStack>

                    <MudText Typo="Typo.body2"
                             Class="text-secondary">
                        @BackupDescriptionText
                    </MudText>
                </MudStack>

                <MudPaper Elevation="0"
                          Class="pa-3 rounded-lg">
                    <MudStack Row="true"
                              Justify="Justify.FlexEnd"
                              AlignItems="AlignItems.Center"
                              Spacing="3">
                        <MudTooltip Text="@ExportButtonTooltipText"
                                    Placement="Placement.Top">
                            <MudButton Color="Color.Primary"
                                       Variant="Variant.Filled"
                                       Disabled="@DataActionsDisabled"
                                       aria-label="@ExportButtonAriaLabel"
                                       Style="@DataActionButtonStyle"
                                       OnClick="ExportDatabaseAsync">
                                @if (_exportInProgress)
                                {
                                    <MudProgressCircular Indeterminate="true"
                                                         Color="Color.Inherit"
                                                         Size="Size.Small"/>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Download"/>
                                }
                            </MudButton>
                        </MudTooltip>

                        <MudTooltip Text="@ShareButtonTooltipText"
                                    Placement="Placement.Top">
                            <span class="d-inline-flex">
                                <MudButton Color="Color.Primary"
                                           Variant="Variant.Filled"
                                           Disabled="@(!DatabaseShareService.CanShare || DataActionsDisabled)"
                                           aria-label="@ShareButtonAriaLabel"
                                           Style="@DataActionButtonStyle"
                                           OnClick="ShareDatabaseAsync">
                                    @if (_shareInProgress)
                                    {
                                        <MudProgressCircular Indeterminate="true"
                                                             Color="Color.Inherit"
                                                             Size="Size.Small"/>
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Share"/>
                                    }
                                </MudButton>
                            </span>
                        </MudTooltip>
                    </MudStack>
                </MudPaper>

                <MudDivider/>

                <MudStack Spacing="1">
                    <MudStack Row="true"
                              Spacing="1"
                              AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">
                            @DiagnosticsHeaderText
                        </MudText>

                        <MudTooltip Text="@DiagnosticsTooltipText"
                                    Placement="Placement.Top">
                            <MudIconButton Icon="@Icons.Material.Filled.Info"
                                           Color="Color.Default"
                                           Size="Size.Small"
                                           aria-label="@DiagnosticsTooltipAriaLabel"/>
                        </MudTooltip>
                    </MudStack>

                    <MudText Typo="Typo.body2"
                             Class="text-secondary">
                        @DiagnosticsDescriptionText
                    </MudText>
                </MudStack>

                <MudPaper Elevation="0"
                          Class="pa-3 rounded-lg">
                    <MudStack Row="true"
                               Justify="Justify.FlexEnd"
                               AlignItems="AlignItems.Center"
                               Spacing="3">
                        <MudTooltip Text="@DiagnosticsExportButtonTooltipText"
                                     Placement="Placement.Top">
                            <MudButton Color="Color.Primary"
                                       Variant="Variant.Filled"
                                       Disabled="@DataActionsDisabled"
                                       aria-label="@DiagnosticsExportButtonAriaLabel"
                                       Style="@DataActionButtonStyle"
                                       OnClick="ExportDiagnosticsAsync">
                                @if (_diagnosticsExportInProgress)
                                {
                                    <MudProgressCircular Indeterminate="true"
                                                         Color="Color.Inherit"
                                                         Size="Size.Small"/>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Download"/>
                                }
                            </MudButton>
                        </MudTooltip>

                        <MudTooltip Text="@DiagnosticsShareButtonTooltipText"
                                    Placement="Placement.Top">
                            <span class="d-inline-flex">
                                <MudButton Color="Color.Primary"
                                           Variant="Variant.Filled"
                                           Disabled="@(!DiagnosticsShareService.CanShare || DataActionsDisabled)"
                                           aria-label="@DiagnosticsShareButtonAriaLabel"
                                           Style="@DataActionButtonStyle"
                                           OnClick="ShareDiagnosticsAsync">
                                    @if (_diagnosticsShareInProgress)
                                    {
                                        <MudProgressCircular Indeterminate="true"
                                                             Color="Color.Inherit"
                                                             Size="Size.Small"/>
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Share"/>
                                    }
                                </MudButton>
                            </span>
                        </MudTooltip>
                    </MudStack>
                </MudPaper>

                <MudDivider/>

                <MudStack Spacing="1">
                    <MudStack Row="true"
                              Spacing="1"
                              AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">
                            @RestoreHeaderText
                        </MudText>

                        <MudTooltip Text="@RestoreWarningText"
                                    Placement="Placement.Top">
                            <MudIconButton Icon="@Icons.Material.Filled.Warning"
                                           Color="Color.Warning"
                                           Size="Size.Small"
                                           aria-label="@RestoreTooltipAriaLabel"/>
                        </MudTooltip>
                    </MudStack>

                    <MudText Typo="Typo.body2"
                             Class="text-secondary">
                        @RestoreDescriptionText
                    </MudText>
                </MudStack>

                <MudPaper Elevation="0"
                          Class="pa-3 rounded-lg">
                    <MudStack Row="true"
                              Justify="Justify.FlexEnd"
                              AlignItems="AlignItems.Center">
                        <MudTooltip Text="@ImportButtonTooltipText"
                                    Placement="Placement.Top">
                            <MudButton Color="Color.Primary"
                                       Variant="Variant.Filled"
                                       Disabled="@DataActionsDisabled"
                                       aria-label="@ImportButtonAriaLabel"
                                       Style="@DataActionButtonStyle"
                                       OnClick="ImportDatabaseAsync">
                                @if (_importInProgress)
                                {
                                    <MudProgressCircular Indeterminate="true"
                                                         Color="Color.Inherit"
                                                         Size="Size.Small"/>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Upload"/>
                                }
                            </MudButton>
                        </MudTooltip>
                    </MudStack>
                </MudPaper>

            </MudStack>
        </MudPaper>
    </MudStack>
</MudContainer>

@code
{

    #region Private Fields, Properties

    private bool _exportInProgress;

    private bool _shareInProgress;

    private bool _importInProgress;

    private bool _diagnosticsExportInProgress;

    private bool _diagnosticsShareInProgress;

    private bool _remindersEnabled;

    private TimeSpan? _reminderTimeLocal;

    private bool _reminderSettingsUpdateInProgress;

    private bool _automatedBackupsEnabled;

    private bool _automatedBackupsSupported;

    private bool _automatedBackupSettingsUpdateInProgress;

    private const bool OneDriveCloudBackupEnabledPlaceholder = false;

    private const bool OneDriveBackupControlsDisabled = true;

    private AppVersionInfo? _appVersionInfo;

    private string? _operationErrorMessage;

    private string? SettingsMetadataBannerText => _appVersionInfo is null
        ? null
        : $"{VersionLabelText} {_appVersionInfo.DisplayVersion} {BuildSeparatorText} {BuildLabelText} {_appVersionInfo.BuildNumber}";

    private bool ReminderControlsDisabled =>
        _reminderSettingsUpdateInProgress
        || _automatedBackupSettingsUpdateInProgress
        || _exportInProgress
        || _diagnosticsExportInProgress
        || _diagnosticsShareInProgress
        || _shareInProgress
        || _importInProgress;

    private bool AutomatedBackupsToggleDisabled =>
        !_automatedBackupsSupported || ReminderControlsDisabled;

    private bool DataActionsDisabled =>
        _exportInProgress
        || _diagnosticsExportInProgress
        || _diagnosticsShareInProgress
        || _shareInProgress
        || _importInProgress
        || _reminderSettingsUpdateInProgress
        || _automatedBackupSettingsUpdateInProgress;

    #endregion

    #region Lifecycle Methods

    protected override async Task OnInitializedAsync()
    {
        var stopwatch = Stopwatch.StartNew();

        try
        {
            _appVersionInfo = AppVersionInfoService.GetCurrent();
            _remindersEnabled = ReminderConfigurationService.GetIsEnabled();
            _reminderTimeLocal = ReminderConfigurationService.GetTimeLocal().ToTimeSpan();
            _automatedBackupsSupported = AutomatedBackupConfigurationService.IsSupported;
            _automatedBackupsEnabled = _automatedBackupsSupported && AutomatedBackupConfigurationService.GetIsEnabled();

            await RequestReminderNotificationPermissionIfEnabledAsync();

            Logger.LogInformation(
                "Settings page initialization completed in {ElapsedMilliseconds} ms. Reminders enabled: {RemindersEnabled}. Automated backups supported: {AutomatedBackupsSupported}. Automated backups enabled: {AutomatedBackupsEnabled}.",
                stopwatch.ElapsedMilliseconds,
                _remindersEnabled,
                _automatedBackupsSupported,
                _automatedBackupsEnabled);
        }
        catch (Exception exception)
        {
            Logger.LogError(
                exception,
                "Settings page initialization failed after {ElapsedMilliseconds} ms.",
                stopwatch.ElapsedMilliseconds);

            throw;
        }
    }

    #endregion

    #region CSS Style Properties

    private const string DataActionButtonStyle = "width: 42px; min-width: 42px; height: 42px; border-radius: 999px; padding: 0;";

    private const string SettingsMetadataBannerStyle = "align-self: center; background-color: var(--mud-palette-primary-hover); color: var(--mud-palette-primary);";

    private const string OneDriveProviderPanelStyle = "border: 1px solid var(--mud-palette-lines-default); background-color: var(--mud-palette-background-grey);";

    private const string OneDriveStatusChipStyle = "background-color: var(--mud-palette-surface); color: var(--mud-palette-text-secondary); border: 1px solid var(--mud-palette-lines-default);";

    #endregion

    #region Event Handlers

    private async Task ReminderEnabledChangedAsync(bool isEnabled)
    {
        try
        {
            _reminderSettingsUpdateInProgress = true;
            _operationErrorMessage = null;
            ReminderConfigurationService.SetIsEnabled(isEnabled);
            _remindersEnabled = isEnabled;

            if (isEnabled)
            {
                await RequestReminderNotificationPermissionIfEnabledAsync();
            }
        }
        catch (Exception)
        {
            _operationErrorMessage = ReminderUpdateFailedText;
            _remindersEnabled = ReminderConfigurationService.GetIsEnabled();
            _reminderTimeLocal = ReminderConfigurationService.GetTimeLocal().ToTimeSpan();
        }
        finally
        {
            _reminderSettingsUpdateInProgress = false;
        }
    }

    private Task ReminderTimeChangedAsync(TimeSpan? reminderTimeLocal)
    {
        return ReminderTimeChangedInternalAsync(reminderTimeLocal);
    }

    private async Task AutomatedBackupsEnabledChangedAsync(bool isEnabled)
    {
        try
        {
            _automatedBackupSettingsUpdateInProgress = true;
            _operationErrorMessage = null;
            AutomatedBackupConfigurationService.SetIsEnabled(isEnabled);
            _automatedBackupsEnabled = isEnabled;

            if (isEnabled)
            {
                var notificationsEnabled = await BackupNotificationPermissionService.RequestPermissionIfNeededAsync();
                if (!notificationsEnabled)
                    Snackbar.Add(AutomatedBackupNotificationsPermissionText, Severity.Info);
            }
        }
        catch (Exception)
        {
            _operationErrorMessage = AutomatedBackupsUpdateFailedText;
            _automatedBackupsEnabled = _automatedBackupsSupported && AutomatedBackupConfigurationService.GetIsEnabled();
        }
        finally
        {
            _automatedBackupSettingsUpdateInProgress = false;
        }
    }

    private async Task ExportDatabaseAsync()
    {
        try
        {
            _exportInProgress = true;
            _operationErrorMessage = null;

            var exportResult = await DatabaseExportService.ExportDatabaseAsync();

            if (exportResult.Status == DatabaseExportStatus.Cancelled)
                return;

            ManualBackupCompletionNotifier.NotifyCompleted(exportResult);
        }
        catch (Exception)
        {
            _operationErrorMessage = ExportFailedText;
        }
        finally
        {
            _exportInProgress = false;
        }
    }

    private async Task ExportDiagnosticsAsync()
    {
        try
        {
            _diagnosticsExportInProgress = true;
            _operationErrorMessage = null;

            var exportResult = await DiagnosticsExportService.ExportDiagnosticsAsync();

            if (exportResult == DiagnosticsExportResult.Cancelled)
                return;
        }
        catch (Exception)
        {
            _operationErrorMessage = DiagnosticsExportFailedText;
        }
        finally
        {
            _diagnosticsExportInProgress = false;
        }
    }

    private async Task ShareDiagnosticsAsync()
    {
        try
        {
            _diagnosticsShareInProgress = true;
            _operationErrorMessage = null;

            await DiagnosticsShareService.ShareDiagnosticsAsync();
        }
        catch (Exception)
        {
            _operationErrorMessage = DiagnosticsShareFailedText;
        }
        finally
        {
            _diagnosticsShareInProgress = false;
        }
    }

    private async Task ShareDatabaseAsync()
    {
        try
        {
            _shareInProgress = true;
            _operationErrorMessage = null;

            await DatabaseShareService.ShareDatabaseAsync();
        }
        catch (Exception)
        {
            _operationErrorMessage = ShareFailedText;
        }
        finally
        {
            _shareInProgress = false;
        }
    }

    private async Task ImportDatabaseAsync()
    {
        try
        {
            _operationErrorMessage = null;

            var selectedBackup = await DatabaseImportFilePicker.PickBackupAsync();
            if (selectedBackup is null)
                return;

            var dialog = await DialogService.ShowAsync<RestoreDatabaseDialog>(RestoreDialogTitleText);
            var result = await dialog.Result;

            if (result is null || result.Canceled)
                return;

            _importInProgress = true;

            await DatabaseImportService.ImportDatabaseAsync(selectedBackup);

            NavigationManager.NavigateTo(RouteConstants.Home, true);
        }
        catch (InvalidDataException)
        {
            _operationErrorMessage = ImportValidationFailedText;
        }
        catch (Exception)
        {
            _operationErrorMessage = ImportFailedText;
        }
        finally
        {
            _importInProgress = false;
        }
    }

    #endregion

    #region Private Helper Methods

    private async Task ReminderTimeChangedInternalAsync(TimeSpan? reminderTimeLocal)
    {
        if (!reminderTimeLocal.HasValue)
            return;

        try
        {
            _reminderSettingsUpdateInProgress = true;
            _operationErrorMessage = null;
            ReminderConfigurationService.SetTimeLocal(TimeOnly.FromTimeSpan(reminderTimeLocal.Value));
            _reminderTimeLocal = reminderTimeLocal;
        }
        catch (Exception)
        {
            _operationErrorMessage = ReminderUpdateFailedText;
            _remindersEnabled = ReminderConfigurationService.GetIsEnabled();
            _reminderTimeLocal = ReminderConfigurationService.GetTimeLocal().ToTimeSpan();
        }
        finally
        {
            _reminderSettingsUpdateInProgress = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RequestReminderNotificationPermissionIfEnabledAsync()
    {
        if (!_remindersEnabled)
            return;

        var notificationsEnabled = await ReminderNotificationPermissionCoordinator.RequestPermissionIfRemindersEnabledAsync();
        if (!notificationsEnabled)
            Snackbar.Add(ReminderNotificationsPermissionText, Severity.Info);
    }

    #endregion

    #region Text, Label Properties

    private const string SettingsPageTitleText = "Settings";

    private const string SettingsMetadataBannerAriaLabel = "App version and build";

    private const string VersionLabelText = "Version";

    private const string BuildLabelText = "Build";

    private const string BuildSeparatorText = "·";

    private const string ReminderSectionEyebrowText = "Reminders";

    private const string ReminderHeaderText = "Daily reminder";

    private const string ReminderToggleLabelText = "Reminders enabled";

    private const string ReminderSwitchAriaLabel = "Daily reminder toggle";

    private const string ReminderTimeLabelText = "Reminder time";

    private const string ReminderHelperText = "You'll be reminded only if there are habits you haven't checked in yet.";

    private const string ReminderUpdateFailedText = "Unable to update reminders right now. Please try again.";

    private const string ReminderNotificationsPermissionText = "Android reminder notifications are off. Daily reminders will stay hidden until you allow notifications.";

    private const string SectionEyebrowText = "Data";

    private const string AutomatedBackupsHeaderText = "Daily automated backups";

    private const string AutomatedBackupsDescriptionText = "Create a nightly backup in local storage.";

    private const string AutomatedBackupsTooltipText = "Android only. Runs nightly at 11:30 PM when enabled.";

    private const string AutomatedBackupsTooltipAriaLabel = "Automated backup details";

    private const string AutomatedBackupsSwitchAriaLabel = "Daily automated backups toggle";

    private const string AutomatedBackupsUpdateFailedText = "Unable to update automated backups right now. Please try again.";

    private const string AutomatedBackupNotificationsPermissionText = "Android backup notifications are off. Nightly backups will still run, but completion notifications stay hidden until you allow notifications.";

    private const string OneDriveBackupHeaderText = "OneDrive backup";

    private const string OneDriveBackupDescriptionText = "Optional cloud backup using your private OneDrive app folder.";

    private const string OneDriveBackupTooltipText = "Optional. Signs in with a personal Microsoft account and uploads the same '.zip' archive to your private OneDrive app folder.";

    private const string OneDriveBackupTooltipAriaLabel = "OneDrive backup details";

    private const string OneDriveProviderNameText = "OneDrive";

    private const string OneDriveProviderStateText = "Not connected";

    private const string OneDriveStatusChipText = "Coming soon";

    private const string OneDriveProviderSupportText = "Cloud backup isn't available in this build yet. These controls are shown here as a placeholder for the upcoming OneDrive flow.";

    private const string CloudAutomatedBackupsLabelText = "Nightly cloud backup";

    private const string CloudAutomatedBackupsDescriptionText = "Will stay separate from local automated backups when available.";

