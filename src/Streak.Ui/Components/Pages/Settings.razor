    #region Private Helper Methods

    private async Task ReminderTimeChangedInternalAsync(TimeSpan? reminderTimeLocal)
    {
        if (!reminderTimeLocal.HasValue)
            return;

        try
        {
            _reminderSettingsUpdateInProgress = true;
            _operationErrorMessage = null;
            ReminderConfigurationService.SetTimeLocal(TimeOnly.FromTimeSpan(reminderTimeLocal.Value));
            _reminderTimeLocal = reminderTimeLocal;
        }
        catch (Exception)
        {
            _operationErrorMessage = ReminderUpdateFailedText;
            _remindersEnabled = ReminderConfigurationService.GetIsEnabled();
            _reminderTimeLocal = ReminderConfigurationService.GetTimeLocal().ToTimeSpan();
        }
        finally
        {
            _reminderSettingsUpdateInProgress = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RequestReminderNotificationPermissionIfEnabledAsync()
    {
        if (!_remindersEnabled)
            return;

        var notificationsEnabled = await ReminderNotificationPermissionCoordinator.RequestPermissionIfRemindersEnabledAsync();
        if (!notificationsEnabled)
            Snackbar.Add(ReminderNotificationsPermissionText, Severity.Info);
    }

    private async Task RefreshOneDriveAuthStateAsync()
    {
        _oneDriveAuthState = await OneDriveAuthService.GetAuthStateAsync();
    }

    private async Task OneDriveCloudBackupEnabledChangedInternalAsync(bool isEnabled)
    {
        try
        {
            _oneDriveCloudBackupSettingsUpdateInProgress = true;
            _operationErrorMessage = null;
            AutomatedBackupConfigurationService.SetIsCloudEnabled(isEnabled);
            _oneDriveCloudBackupEnabled = isEnabled;
        }
        catch (Exception)
        {
            _operationErrorMessage = OneDriveCloudAutomatedBackupUpdateFailedText;
            _oneDriveCloudBackupEnabled = _automatedBackupsSupported && AutomatedBackupConfigurationService.GetIsCloudEnabled();
        }
        finally
        {
            _oneDriveCloudBackupSettingsUpdateInProgress = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void RefreshManualBackupStatusMetadata()
    {
        _lastSuccessfulLocalManualBackupUtc = ManualBackupStatusStore.GetLastSuccessfulBackupUtc(ManualBackupLocation.Local);
        _lastSuccessfulCloudManualBackupUtc = ManualBackupStatusStore.GetLastSuccessfulBackupUtc(ManualBackupLocation.Cloud);
    }

    private string? FormatLastBackupMetadataText(DateTimeOffset? completedAtUtc)
    {
        if (!completedAtUtc.HasValue)
            return null;

        var localCompletedAt = TimeZoneInfo.ConvertTime(completedAtUtc.Value, TimeProvider.LocalTimeZone);
        var localNow = TimeZoneInfo.ConvertTime(TimeProvider.GetUtcNow(), TimeProvider.LocalTimeZone);
        var dayLabel = localCompletedAt.Date == localNow.Date
            ? TodayLabelText
            : localCompletedAt.ToString("MMM d, yyyy", CultureInfo.InvariantCulture);
        var timeLabel = localCompletedAt.ToString("h:mm tt", CultureInfo.InvariantCulture);

        return $"{LastBackupLabelText} {dayLabel} {BuildSeparatorText} {timeLabel}";
    }

    private static string GetOneDriveManualBackupFailureText(OneDriveBackupFailureKind failureKind)
    {
        return failureKind switch
        {
            OneDriveBackupFailureKind.AuthRequired => OneDriveManualBackupReconnectRequiredText,
            OneDriveBackupFailureKind.AccessDenied => OneDriveManualBackupAccessDeniedText,
            OneDriveBackupFailureKind.NetworkUnavailable => OneDriveManualBackupNetworkFailedText,
            OneDriveBackupFailureKind.QuotaExceeded => OneDriveManualBackupQuotaExceededText,
            _ => OneDriveManualBackupFailedText
        };
    }

