@page "/settings"
@inject IAutomatedBackupConfigurationService AutomatedBackupConfigurationService
@inject IReminderConfigurationService ReminderConfigurationService
@inject IDatabaseExportService DatabaseExportService
@inject IDiagnosticsExportService DiagnosticsExportService
@inject IDatabaseShareService DatabaseShareService
@inject IDiagnosticsShareService DiagnosticsShareService
@inject IDatabaseImportFilePicker DatabaseImportFilePicker
@inject IDatabaseImportService DatabaseImportService
@inject IManualBackupCompletionNotifier ManualBackupCompletionNotifier
@inject IManualBackupStatusStore ManualBackupStatusStore
@inject IManualCloudBackupService ManualCloudBackupService
@inject IBackupNotificationPermissionService BackupNotificationPermissionService
@inject IReminderNotificationPermissionCoordinator ReminderNotificationPermissionCoordinator
@inject IAppVersionInfoService AppVersionInfoService
@inject IOneDriveAuthService OneDriveAuthService
@inject IOneDriveAuthReturnRouteStore OneDriveAuthReturnRouteStore
@inject TimeProvider TimeProvider
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject ILogger<Settings> Logger

<PageTitle>@SettingsPageTitleText</PageTitle>
<AppBarTitleScope TitleText="@SettingsPageTitleText"/>

<MudContainer MaxWidth="MaxWidth.Small"
              Class="pa-4">
    <MudStack Spacing="3">
        @if (!string.IsNullOrWhiteSpace(SettingsMetadataBannerText))
        {
            <MudPaper Elevation="0"
                      Class="px-3 py-1 rounded-pill"
                      Style="@SettingsMetadataBannerStyle"
                      aria-label="@SettingsMetadataBannerAriaLabel">
                <MudStack Row="true"
                          AlignItems="AlignItems.Center"
                          Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.Info"
                             Size="Size.Small"/>
                    <MudText Typo="Typo.body2">
                        @SettingsMetadataBannerText
                    </MudText>
                </MudStack>
            </MudPaper>
        }

        @if (!string.IsNullOrWhiteSpace(_operationErrorMessage))
        {
            <MudAlert Severity="Severity.Error"
                      Dense="true">
                @_operationErrorMessage
            </MudAlert>
        }

        <MudPaper Elevation="1"
                  Class="pa-4 rounded-lg">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">
                    @ReminderHeaderText
                </MudText>

                <MudPaper Elevation="0"
                          Class="pa-3 rounded-lg">
                    <MudStack Row="true"
                              Justify="Justify.SpaceBetween"
                              AlignItems="AlignItems.Center"
                              Spacing="3">
                        <MudText Typo="Typo.body1">
                            @ReminderToggleLabelText
                        </MudText>

                        <MudSwitch T="bool"
                                   Value="@_remindersEnabled"
                                   ValueChanged="ReminderEnabledChangedAsync"
                                   Disabled="@ReminderControlsDisabled"
                                   Color="Color.Primary"
                                   aria-label="@ReminderSwitchAriaLabel"/>
                    </MudStack>
                </MudPaper>

                @if (_remindersEnabled)
                {
                    <MudPaper Elevation="0"
                              Class="pa-3 rounded-lg">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.body2">
                                @ReminderTimeLabelText
                            </MudText>

                            <MudTimePicker Time="@_reminderTimeLocal"
                                           TimeChanged="ReminderTimeChangedAsync"
                                           Label="@ReminderTimeLabelText"
                                           AmPm="true"
                                           Variant="Variant.Outlined"
                                           Disabled="@ReminderControlsDisabled" />
                        </MudStack>
                    </MudPaper>
                }

                <MudText Typo="Typo.caption"
                         Class="text-secondary">
                    @ReminderHelperText
                </MudText>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="1"
                  Class="pa-4 rounded-lg">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">
                    @LocalBackupHeaderText
                </MudText>

                <MudStack Spacing="1">
                    <MudStack Row="true"
                              Spacing="1"
                              AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">
                            @AutomatedBackupsHeaderText
                        </MudText>

                        <MudTooltip Text="@AutomatedBackupsTooltipText"
                                    Placement="Placement.Top">
                            <MudIconButton Icon="@Icons.Material.Filled.Info"
                                            Color="Color.Default"
                                            Size="Size.Small"
                                            aria-label="@AutomatedBackupsTooltipAriaLabel"/>
                        </MudTooltip>
                    </MudStack>

                    <MudText Typo="Typo.body2"
                             Class="text-secondary">
                        @AutomatedBackupsDescriptionText
                    </MudText>
                </MudStack>

                <MudPaper Elevation="0"
                          Class="pa-3 rounded-lg">
                    <MudStack Row="true"
                              Justify="Justify.FlexEnd"
                              AlignItems="AlignItems.Center"
                              Spacing="0">
                        <MudSwitch T="bool"
                                   Value="@_automatedBackupsEnabled"
                                   ValueChanged="AutomatedBackupsEnabledChangedAsync"
                                   Disabled="@AutomatedBackupsToggleDisabled"
                                   Color="Color.Primary"
                                   aria-label="@AutomatedBackupsSwitchAriaLabel"/>
                    </MudStack>
                </MudPaper>

                <MudDivider/>

                <MudStack Spacing="1">
                    <MudStack Row="true"
                              Spacing="1"
                              AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">
                            @ManualBackupHeaderText
                        </MudText>

                        <MudTooltip Text="@ManualBackupTooltipText"
                                    Placement="Placement.Top">
                            <MudIconButton Icon="@Icons.Material.Filled.Info"
                                           Color="Color.Default"
                                           Size="Size.Small"
                                           aria-label="@ManualBackupTooltipAriaLabel"/>
                        </MudTooltip>
                    </MudStack>

                    <MudText Typo="Typo.body2"
                             Class="text-secondary">
                        @ManualBackupDescriptionText
                    </MudText>

                    @if (!string.IsNullOrWhiteSpace(LocalManualBackupMetadataText))
                    {
                        <MudText Typo="Typo.caption"
                                 Class="text-secondary">
                            @LocalManualBackupMetadataText
                        </MudText>
                    }
                </MudStack>

                <MudPaper Elevation="0"
                          Class="pa-3 rounded-lg">
                    <MudStack Row="true"
                              Justify="Justify.FlexEnd"
                              AlignItems="AlignItems.Center"
                              Spacing="3">
                        <MudTooltip Text="@ExportButtonTooltipText"
                                    Placement="Placement.Top">
                            <MudButton Color="Color.Primary"
                                       Variant="Variant.Filled"
                                       Disabled="@DataActionsDisabled"
                                       aria-label="@ExportButtonAriaLabel"
                                       Style="@DataActionButtonStyle"
                                       OnClick="ExportDatabaseAsync">
                                @if (_exportInProgress)
                                {
                                    <MudProgressCircular Indeterminate="true"
                                                         Color="Color.Inherit"
                                                         Size="Size.Small"/>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Download"/>
                                }
                            </MudButton>
                        </MudTooltip>

                        <MudTooltip Text="@ShareButtonTooltipText"
                                    Placement="Placement.Top">
                            <span class="d-inline-flex">
                                <MudButton Color="Color.Primary"
                                           Variant="Variant.Filled"
                                           Disabled="@(!DatabaseShareService.CanShare || DataActionsDisabled)"
                                           aria-label="@ShareButtonAriaLabel"
                                           Style="@DataActionButtonStyle"
                                           OnClick="ShareDatabaseAsync">
                                    @if (_shareInProgress)
                                    {
                                        <MudProgressCircular Indeterminate="true"
                                                             Color="Color.Inherit"
                                                             Size="Size.Small"/>
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Share"/>
                                    }
                                </MudButton>
                            </span>
                        </MudTooltip>
                    </MudStack>
                </MudPaper>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="1"
                  Class="pa-4 rounded-lg">
            <MudStack Spacing="3">
                <MudStack Spacing="1">
                    <MudStack Row="true"
                              Spacing="1"
                              AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">
                            @CloudBackupHeaderText
                        </MudText>

                        <MudTooltip Text="@CloudBackupTooltipText"
                                    Placement="Placement.Top">
                            <MudIconButton Icon="@Icons.Material.Filled.Info"
                                           Color="Color.Default"
                                           Size="Size.Small"
                                           aria-label="@CloudBackupTooltipAriaLabel"/>
                        </MudTooltip>
                    </MudStack>

                    <MudText Typo="Typo.body2"
                             Class="text-secondary">
                        @CloudBackupDescriptionText
                    </MudText>
                </MudStack>

                <MudPaper Elevation="0"
                          Class="pa-3 rounded-lg"
                          Style="@OneDriveProviderPanelStyle">
                    <MudStack Spacing="2">
                        @if (_oneDriveAuthState.IsConnected)
                        {
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body1">
                                    @OneDriveConnectionHeaderText
                                </MudText>

                                <MudText Typo="Typo.caption"
                                         Class="text-secondary">
                                    @OneDriveConnectionDescriptionText
                                </MudText>
                            </MudStack>
                        }

                        <MudStack Row="true"
                                  AlignItems="AlignItems.Center"
                                  Spacing="2">
                            <MudTooltip Text="@OneDriveProviderButtonTooltipText"
                                        Placement="Placement.Top">
                                <span class="d-inline-flex">
                                    <MudButton Color="@OneDriveProviderStatusIconColor"
                                               Variant="Variant.Filled"
                                               Disabled="@OneDriveProviderButtonDisabled"
                                               Style="@DataActionButtonStyle"
                                               OnClick="HandleOneDriveProviderButtonClickAsync"
                                               aria-label="@OneDriveProviderButtonAriaLabel">
                                        <MudIcon Icon="@OneDriveProviderStatusIcon"/>
                                    </MudButton>
                                </span>
                            </MudTooltip>

                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body1">
                                    @OneDriveProviderNameText
                                </MudText>

                                <MudText Typo="Typo.caption"
                                         Class="text-secondary">
                                    @OneDriveProviderStateText
                                </MudText>

                                <MudText Typo="Typo.caption"
                                         Class="text-secondary">
                                    @OneDriveProviderSupportText
                                </MudText>
                            </MudStack>
                        </MudStack>

                        @if (_oneDriveAuthState.IsConnected)
                        {
                            <MudDivider/>

                            <MudStack Spacing="1">
                                <MudStack Row="true"
                                          Spacing="1"
                                          AlignItems="AlignItems.Center">
                                    <MudText Typo="Typo.body1">
                                        @CloudManualBackupHeaderText
                                    </MudText>

                                    <MudTooltip Text="@CloudManualBackupTooltipText"
                                                Placement="Placement.Top">
                                        <MudIconButton Icon="@Icons.Material.Filled.Info"
                                                       Color="Color.Default"
                                                       Size="Size.Small"
                                                       aria-label="@CloudManualBackupTooltipAriaLabel"/>
                                    </MudTooltip>
                                </MudStack>

                                <MudText Typo="Typo.caption"
                                         Class="text-secondary">
                                    @CloudManualBackupDescriptionText
                                </MudText>

                                @if (!string.IsNullOrWhiteSpace(CloudManualBackupMetadataText))
                                {
                                    <MudText Typo="Typo.caption"
                                             Class="text-secondary">
                                        @CloudManualBackupMetadataText
                                    </MudText>
                                }
                            </MudStack>

                            <MudStack Row="true"
                                      Justify="Justify.FlexEnd"
                                      AlignItems="AlignItems.Center">
                                <MudTooltip Text="@BackUpToOneDriveButtonTooltipText"
                                            Placement="Placement.Top">
                                    <span class="d-inline-flex">
                                        <MudButton Color="Color.Primary"
                                                   Variant="Variant.Filled"
                                                   Disabled="@OneDriveManualBackupButtonDisabled"
                                                   aria-label="@BackUpToOneDriveButtonAriaLabel"
                                                   Style="@DataActionButtonStyle"
                                                   OnClick="UploadManualCloudBackupAsync">
                                            @if (_oneDriveManualBackupInProgress)
                                            {
                                                <MudProgressCircular Indeterminate="true"
                                                                     Color="Color.Inherit"
                                                                     Size="Size.Small"/>
                                            }
                                            else
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.Backup"/>
                                            }
                                        </MudButton>
                                    </span>
                                </MudTooltip>
                            </MudStack>

                            <MudDivider/>

                            <MudStack Spacing="1">
                                <MudStack Row="true"
                                          Spacing="1"
                                          AlignItems="AlignItems.Center">
                                    <MudText Typo="Typo.body1">
                                        @CloudAutomatedBackupsHeaderText
                                    </MudText>

                                    <MudTooltip Text="@CloudAutomatedBackupsTooltipText"
                                                Placement="Placement.Top">
                                        <MudIconButton Icon="@Icons.Material.Filled.Info"
                                                       Color="Color.Default"
                                                       Size="Size.Small"
                                                       aria-label="@CloudAutomatedBackupsTooltipAriaLabel"/>
                                    </MudTooltip>
                                </MudStack>

                                <MudText Typo="Typo.caption"
                                         Class="text-secondary">
                                    @CloudAutomatedBackupsDescriptionText
                                </MudText>
                            </MudStack>

                            <MudStack Row="true"
                                      Justify="Justify.FlexEnd"
                                      AlignItems="AlignItems.Center"
                                      Spacing="0">
                                <MudSwitch T="bool"
                                           Value="@_oneDriveCloudBackupEnabled"
                                           ValueChanged="OneDriveCloudBackupEnabledChangedAsync"
                                           Disabled="@OneDriveCloudBackupToggleDisabled"
                                           Color="Color.Primary"
                                           aria-label="@CloudAutomatedBackupsSwitchAriaLabel"/>
                            </MudStack>
                        }
                    </MudStack>
                </MudPaper>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="1"
                  Class="pa-4 rounded-lg">
            <MudStack Spacing="3">
                <MudStack Spacing="1">
                    <MudStack Row="true"
                              Spacing="1"
                              AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">
                            @RestoreHeaderText
                        </MudText>

                        <MudTooltip Text="@RestoreWarningText"
                                    Placement="Placement.Top">
                            <MudIconButton Icon="@Icons.Material.Filled.Warning"
                                           Color="Color.Warning"
                                           Size="Size.Small"
                                           aria-label="@RestoreTooltipAriaLabel"/>
                        </MudTooltip>
                    </MudStack>

                    <MudText Typo="Typo.body2"
                             Class="text-secondary">
                        @RestoreDescriptionText
                    </MudText>
                </MudStack>

                <MudPaper Elevation="0"
                          Class="pa-3 rounded-lg">
                    <MudStack Row="true"
                              Justify="Justify.FlexEnd"
                              AlignItems="AlignItems.Center">
                        <MudTooltip Text="@ImportButtonTooltipText"
                                     Placement="Placement.Top">
                            <MudButton Color="Color.Primary"
                                       Variant="Variant.Filled"
                                       Disabled="@DataActionsDisabled"
                                       aria-label="@ImportButtonAriaLabel"
                                       Style="@DataActionButtonStyle"
                                       OnClick="ImportDatabaseAsync">
                                @if (_importInProgress)
                                {
                                    <MudProgressCircular Indeterminate="true"
                                                         Color="Color.Inherit"
                                                         Size="Size.Small"/>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Upload"/>
                                }
                            </MudButton>
                        </MudTooltip>
                    </MudStack>
                </MudPaper>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="1"
                  Class="pa-4 rounded-lg">
            <MudStack Spacing="3">
                <MudStack Spacing="1">
                    <MudStack Row="true"
                              Spacing="1"
                              AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">
                            @DiagnosticsHeaderText
                        </MudText>

                        <MudTooltip Text="@DiagnosticsTooltipText"
                                    Placement="Placement.Top">
                            <MudIconButton Icon="@Icons.Material.Filled.Info"
                                           Color="Color.Default"
                                           Size="Size.Small"
                                           aria-label="@DiagnosticsTooltipAriaLabel"/>
                        </MudTooltip>
                    </MudStack>

                    <MudText Typo="Typo.body2"
                             Class="text-secondary">
                        @DiagnosticsDescriptionText
                    </MudText>
                </MudStack>

                <MudPaper Elevation="0"
                          Class="pa-3 rounded-lg">
                    <MudStack Row="true"
                              Justify="Justify.FlexEnd"
                              AlignItems="AlignItems.Center"
                              Spacing="3">
                        <MudTooltip Text="@DiagnosticsExportButtonTooltipText"
                                     Placement="Placement.Top">
                            <MudButton Color="Color.Primary"
                                       Variant="Variant.Filled"
                                       Disabled="@DataActionsDisabled"
                                       aria-label="@DiagnosticsExportButtonAriaLabel"
                                       Style="@DataActionButtonStyle"
                                       OnClick="ExportDiagnosticsAsync">
                                @if (_diagnosticsExportInProgress)
                                {
                                    <MudProgressCircular Indeterminate="true"
                                                         Color="Color.Inherit"
                                                         Size="Size.Small"/>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Download"/>
                                }
                            </MudButton>
                        </MudTooltip>

                        <MudTooltip Text="@DiagnosticsShareButtonTooltipText"
                                    Placement="Placement.Top">
                            <span class="d-inline-flex">
                                <MudButton Color="Color.Primary"
                                           Variant="Variant.Filled"
                                           Disabled="@(!DiagnosticsShareService.CanShare || DataActionsDisabled)"
                                           aria-label="@DiagnosticsShareButtonAriaLabel"
                                           Style="@DataActionButtonStyle"
                                           OnClick="ShareDiagnosticsAsync">
                                    @if (_diagnosticsShareInProgress)
                                    {
                                        <MudProgressCircular Indeterminate="true"
                                                             Color="Color.Inherit"
                                                             Size="Size.Small"/>
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Share"/>
                                    }
                                </MudButton>
                            </span>
                        </MudTooltip>
                    </MudStack>
                </MudPaper>
            </MudStack>
        </MudPaper>
    </MudStack>
</MudContainer>

@code
{

    #region Private Fields, Properties

    private bool _exportInProgress;

    private bool _shareInProgress;

    private bool _importInProgress;

    private bool _diagnosticsExportInProgress;

    private bool _diagnosticsShareInProgress;

    private bool _oneDriveManualBackupInProgress;

    private bool _remindersEnabled;

    private TimeSpan? _reminderTimeLocal;

    private bool _reminderSettingsUpdateInProgress;

    private bool _automatedBackupsEnabled;

    private bool _automatedBackupsSupported;

    private bool _automatedBackupSettingsUpdateInProgress;

    private bool _oneDriveCloudBackupEnabled;

    private bool _oneDriveCloudBackupSettingsUpdateInProgress;

    private OneDriveAuthState _oneDriveAuthState = new();

    private bool _oneDriveAuthOperationInProgress;

    private AppVersionInfo? _appVersionInfo;

    private DateTimeOffset? _lastSuccessfulLocalManualBackupUtc;

    private DateTimeOffset? _lastSuccessfulCloudManualBackupUtc;

    private string? _operationErrorMessage;

    private string? SettingsMetadataBannerText => _appVersionInfo is null
        ? null
        : $"{VersionLabelText} {_appVersionInfo.DisplayVersion} {BuildSeparatorText} {BuildLabelText} {_appVersionInfo.BuildNumber}";

    private bool ReminderControlsDisabled =>
        _reminderSettingsUpdateInProgress
        || _automatedBackupSettingsUpdateInProgress
        || _oneDriveCloudBackupSettingsUpdateInProgress
        || _oneDriveAuthOperationInProgress
        || _exportInProgress
        || _diagnosticsExportInProgress
        || _diagnosticsShareInProgress
        || _shareInProgress
        || _importInProgress
        || _oneDriveManualBackupInProgress;

    private bool AutomatedBackupsToggleDisabled =>
        !_automatedBackupsSupported || ReminderControlsDisabled;

    private bool DataActionsDisabled =>
        _exportInProgress
        || _diagnosticsExportInProgress
        || _diagnosticsShareInProgress
        || _shareInProgress
        || _importInProgress
        || _oneDriveManualBackupInProgress
        || _reminderSettingsUpdateInProgress
        || _automatedBackupSettingsUpdateInProgress
        || _oneDriveCloudBackupSettingsUpdateInProgress
        || _oneDriveAuthOperationInProgress;

    private bool OneDriveCloudBackupToggleDisabled =>
        !_automatedBackupsSupported
        || !_oneDriveAuthState.IsConnected
        || DataActionsDisabled;

    private bool OneDriveManualBackupButtonDisabled =>
        DataActionsDisabled || !_oneDriveAuthState.IsConnected;

    private bool OneDriveProviderButtonDisabled =>
        DataActionsDisabled
        || !_oneDriveAuthState.IsPlatformSupported
        || !_oneDriveAuthState.IsConfigured;

    private string OneDriveProviderStateText => _oneDriveAuthState.IsConnected
        ? _oneDriveAuthState.AccountUsername ?? OneDriveConnectedStateText
        : OneDrivePersonalMicrosoftAccountText;

    private string OneDriveProviderSupportText
    {
        get
        {
            if (!_oneDriveAuthState.IsPlatformSupported)
                return OneDrivePlatformUnsupportedSupportText;

            if (!_oneDriveAuthState.IsConfigured)
                return OneDriveNotConfiguredSupportText;

            return _oneDriveAuthState.IsConnected
                ? OneDriveConnectedSupportText
                : OneDriveSignedOutSupportText;
        }
    }

    private string OneDriveProviderButtonAriaLabel
    {
        get
        {
            if (!_oneDriveAuthState.IsPlatformSupported)
                return OneDriveUnavailableStatusText;

            if (!_oneDriveAuthState.IsConfigured)
                return OneDriveSetupRequiredStatusText;

            return _oneDriveAuthState.IsConnected
                ? OneDriveDisconnectButtonAriaLabel
                : OneDriveConnectButtonAriaLabel;
        }
    }

    private string OneDriveProviderButtonTooltipText => OneDriveProviderButtonAriaLabel;

    private string OneDriveProviderStatusIcon => _oneDriveAuthState.IsConnected
        ? Icons.Material.Filled.CloudDone
        : Icons.Material.Filled.CloudOff;

    private Color OneDriveProviderStatusIconColor => _oneDriveAuthState.IsConnected
        ? Color.Success
        : Color.Error;

    private string? LocalManualBackupMetadataText => FormatLastBackupMetadataText(_lastSuccessfulLocalManualBackupUtc);

    private string? CloudManualBackupMetadataText => FormatLastBackupMetadataText(_lastSuccessfulCloudManualBackupUtc);

    #endregion

    #region Lifecycle Methods

    protected override async Task OnInitializedAsync()
    {
        var stopwatch = Stopwatch.StartNew();

        try
        {
            _appVersionInfo = AppVersionInfoService.GetCurrent();
            _remindersEnabled = ReminderConfigurationService.GetIsEnabled();
            _reminderTimeLocal = ReminderConfigurationService.GetTimeLocal().ToTimeSpan();
            _automatedBackupsSupported = AutomatedBackupConfigurationService.IsSupported;
            _automatedBackupsEnabled = _automatedBackupsSupported && AutomatedBackupConfigurationService.GetIsEnabled();
            _oneDriveCloudBackupEnabled = _automatedBackupsSupported && AutomatedBackupConfigurationService.GetIsCloudEnabled();
            _oneDriveAuthState = await OneDriveAuthService.GetAuthStateAsync();
            RefreshManualBackupStatusMetadata();

            await RequestReminderNotificationPermissionIfEnabledAsync();

            Logger.LogInformation(
                "Settings page initialization completed in {ElapsedMilliseconds} ms. Reminders enabled: {RemindersEnabled}. Automated backups supported: {AutomatedBackupsSupported}. Automated local backups enabled: {AutomatedBackupsEnabled}. Automated cloud backups enabled: {AutomatedCloudBackupsEnabled}. OneDrive supported: {OneDrivePlatformSupported}. OneDrive configured: {OneDriveConfigured}. OneDrive connected: {OneDriveConnected}.",
                stopwatch.ElapsedMilliseconds,
                _remindersEnabled,
                _automatedBackupsSupported,
                _automatedBackupsEnabled,
                _oneDriveCloudBackupEnabled,
                _oneDriveAuthState.IsPlatformSupported,
                _oneDriveAuthState.IsConfigured,
                _oneDriveAuthState.IsConnected);
        }
        catch (Exception exception)
        {
            Logger.LogError(
                exception,
                "Settings page initialization failed after {ElapsedMilliseconds} ms.",
                stopwatch.ElapsedMilliseconds);

            throw;
        }
    }

    #endregion

    #region CSS Style Properties

    private const string DataActionButtonStyle = "width: 42px; min-width: 42px; height: 42px; border-radius: 999px; padding: 0;";

    private const string SettingsMetadataBannerStyle = "align-self: center; background-color: var(--mud-palette-primary-hover); color: var(--mud-palette-primary);";

    private const string OneDriveProviderPanelStyle = "border: 1px solid var(--mud-palette-lines-default); background-color: var(--mud-palette-background-grey);";

    #endregion

    #region Event Handlers

    private async Task ReminderEnabledChangedAsync(bool isEnabled)
    {
        try
        {
            _reminderSettingsUpdateInProgress = true;
            _operationErrorMessage = null;
            ReminderConfigurationService.SetIsEnabled(isEnabled);
            _remindersEnabled = isEnabled;

            if (isEnabled)
            {
                await RequestReminderNotificationPermissionIfEnabledAsync();
            }
        }
        catch (Exception)
        {
            _operationErrorMessage = ReminderUpdateFailedText;
            _remindersEnabled = ReminderConfigurationService.GetIsEnabled();
            _reminderTimeLocal = ReminderConfigurationService.GetTimeLocal().ToTimeSpan();
        }
        finally
        {
            _reminderSettingsUpdateInProgress = false;
        }
    }

    private Task ReminderTimeChangedAsync(TimeSpan? reminderTimeLocal)
    {
        return ReminderTimeChangedInternalAsync(reminderTimeLocal);
    }

    private async Task AutomatedBackupsEnabledChangedAsync(bool isEnabled)
    {
        try
        {
            _automatedBackupSettingsUpdateInProgress = true;
            _operationErrorMessage = null;
            AutomatedBackupConfigurationService.SetIsEnabled(isEnabled);
            _automatedBackupsEnabled = isEnabled;

            if (isEnabled)
            {
                var notificationsEnabled = await BackupNotificationPermissionService.RequestPermissionIfNeededAsync();
                if (!notificationsEnabled)
                    Snackbar.Add(AutomatedBackupNotificationsPermissionText, Severity.Info);
            }
        }
        catch (Exception)
        {
            _operationErrorMessage = AutomatedBackupsUpdateFailedText;
            _automatedBackupsEnabled = _automatedBackupsSupported && AutomatedBackupConfigurationService.GetIsEnabled();
        }
        finally
        {
            _automatedBackupSettingsUpdateInProgress = false;
        }
    }

    private Task OneDriveCloudBackupEnabledChangedAsync(bool isEnabled)
    {
        return OneDriveCloudBackupEnabledChangedInternalAsync(isEnabled);
    }

    private async Task ExportDatabaseAsync()
    {
        try
        {
            _exportInProgress = true;
            _operationErrorMessage = null;

            var exportResult = await DatabaseExportService.ExportDatabaseAsync();

            if (exportResult.Status == DatabaseExportStatus.Cancelled)
                return;

            ManualBackupCompletionNotifier.NotifyCompleted(exportResult);
            RefreshManualBackupStatusMetadata();
        }
        catch (Exception)
        {
            _operationErrorMessage = ExportFailedText;
        }
        finally
        {
            _exportInProgress = false;
        }
    }

    private async Task ConnectOneDriveAsync()
    {
        try
        {
            _oneDriveAuthOperationInProgress = true;
            _operationErrorMessage = null;
            Logger.LogInformation("Settings started OneDrive connect flow and persisted the post-auth return route.");
            OneDriveAuthReturnRouteStore.SetPendingReturnRoute(RouteConstants.Settings);

            var connectResult = await OneDriveAuthService.ConnectAsync();
            _oneDriveAuthState = connectResult.AuthState;
            OneDriveAuthReturnRouteStore.ClearPendingReturnRoute();
            Logger.LogInformation(
                "Settings completed OneDrive connect flow. Status: {OneDriveConnectStatus}. Connected: {OneDriveConnected}.",
                connectResult.Status,
                _oneDriveAuthState.IsConnected);
        }
        catch (Exception exception)
        {
            Logger.LogWarning(
                exception,
                "Settings OneDrive connect flow failed or was interrupted; clearing the post-auth return route and refreshing auth state.");
            _operationErrorMessage = OneDriveConnectFailedText;
            OneDriveAuthReturnRouteStore.ClearPendingReturnRoute();
            await RefreshOneDriveAuthStateAsync();
        }
        finally
        {
            _oneDriveAuthOperationInProgress = false;
        }
    }

    private async Task DisconnectOneDriveAsync()
    {
        try
        {
            _oneDriveAuthOperationInProgress = true;
            _operationErrorMessage = null;

            await OneDriveAuthService.DisconnectAsync();
            await RefreshOneDriveAuthStateAsync();
        }
        catch (Exception)
        {
            _operationErrorMessage = OneDriveDisconnectFailedText;
            await RefreshOneDriveAuthStateAsync();
        }
        finally
        {
            _oneDriveAuthOperationInProgress = false;
        }
    }

    private Task HandleOneDriveProviderButtonClickAsync()
    {
        return _oneDriveAuthState.IsConnected
            ? DisconnectOneDriveAsync()
            : ConnectOneDriveAsync();
    }

    private async Task UploadManualCloudBackupAsync()
    {
        try
        {
            _oneDriveManualBackupInProgress = true;
            _operationErrorMessage = null;

            await ManualCloudBackupService.UploadManualBackupAsync();
            RefreshManualBackupStatusMetadata();
            Snackbar.Add(OneDriveManualBackupCompletedText, Severity.Success);
        }
        catch (OneDriveBackupException exception)
        {
            if (exception.FailureKind == OneDriveBackupFailureKind.AuthRequired)
                await RefreshOneDriveAuthStateAsync();

            _operationErrorMessage = GetOneDriveManualBackupFailureText(exception.FailureKind);
        }
        catch (Exception)
        {
            _operationErrorMessage = OneDriveManualBackupFailedText;
        }
        finally
        {
            _oneDriveManualBackupInProgress = false;
        }
    }

