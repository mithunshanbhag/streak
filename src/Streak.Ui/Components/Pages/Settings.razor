@page "/settings"
@using Streak.Ui.Models.ViewModels.InputModels
@using Streak.Ui.Services.Interfaces
@inject ICoreAppService CoreAppService
@inject ISnackbar Snackbar

@if (_isLoading)
{
    <div class="loading-container">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </div>
}
else
{
    <div class="settings-page">
        <MudPaper Class="settings-card" Elevation="1">
            <MudText Typo="Typo.subtitle1" Class="section-title">Daily Reminder</MudText>

            <div class="settings-row">
                <MudText Typo="Typo.body1">Enable reminders</MudText>
                <MudSwitch T="bool"
                           Color="Color.Primary"
                           Value="_isReminderEnabled"
                           ValueChanged="OnReminderEnabledChanged" />
            </div>

            @if (_isReminderEnabled)
            {
                <div class="settings-row time-row">
                    <MudText Typo="Typo.body1">Reminder time</MudText>
                    <MudTimePicker Time="_reminderTimeLocal"
                                   TimeChanged="OnReminderTimeChanged"
                                   AmPm="true"
                                   AutoClose="true"
                                   MinuteSelectionStep="5"
                                   OpenTo="OpenTo.Hours" />
                </div>
            }
        </MudPaper>

        <MudText Typo="Typo.caption" Color="Color.Secondary">
            You'll be reminded only if there are habits you haven't checked in yet.
        </MudText>
    </div>
}

@code
{
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _hasLoadedSettings;
    private bool _isReminderEnabled = true;
    private TimeSpan? _reminderTimeLocal = TimeSpan.Parse(CoreConstants.DefaultReminderTimeLocal);

    protected override async Task OnInitializedAsync()
    {
        await LoadSettingsAsync();
    }

    private async Task LoadSettingsAsync()
    {
        _isLoading = true;
        try
        {
            var reminderSettings = await CoreAppService.GetReminderSettingsAsync();
            _isReminderEnabled = reminderSettings.IsReminderEnabled;
            _reminderTimeLocal = reminderSettings.ReminderTimeLocal;
            _hasLoadedSettings = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnReminderEnabledChanged(bool isEnabled)
    {
        _isReminderEnabled = isEnabled;
        await PersistReminderSettingsAsync();
    }

    private async Task OnReminderTimeChanged(TimeSpan? reminderTime)
    {
        if (!reminderTime.HasValue)
            return;

        _reminderTimeLocal = reminderTime.Value;
        await PersistReminderSettingsAsync();
    }

    private async Task PersistReminderSettingsAsync()
    {
        if (!_hasLoadedSettings || _isSaving || !_reminderTimeLocal.HasValue)
            return;

        _isSaving = true;
        try
        {
            await CoreAppService.UpdateReminderSettingsAsync(new ReminderSettingsUpdateInputModel
            {
                IsReminderEnabled = _isReminderEnabled,
                ReminderTimeLocal = _reminderTimeLocal.Value
            });
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }
}
