@page "/settings"
@inject IAutomatedBackupConfigurationService AutomatedBackupConfigurationService
@inject IDatabaseExportService DatabaseExportService
@inject IDatabaseShareService DatabaseShareService
@inject IDatabaseImportFilePicker DatabaseImportFilePicker
@inject IDatabaseImportService DatabaseImportService
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<PageTitle>Settings</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small"
              Class="pa-4">
    <MudStack Spacing="3">
        @if (!string.IsNullOrWhiteSpace(_operationErrorMessage))
        {
            <MudAlert Severity="Severity.Error"
                      Dense="true">
                @_operationErrorMessage
            </MudAlert>
        }

        <MudPaper Elevation="1"
                  Class="pa-4 rounded-lg">
            <MudStack Spacing="3">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption"
                             Class="text-secondary">
                        @SectionEyebrowText
                    </MudText>
                </MudStack>

                <MudStack Spacing="1">
                    <MudStack Row="true"
                              Spacing="1"
                              AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">
                            @AutomatedBackupsHeaderText
                        </MudText>

                        <MudTooltip Text="@AutomatedBackupsTooltipText"
                                    Placement="Placement.Top">
                            <MudIconButton Icon="@Icons.Material.Filled.Info"
                                            Color="Color.Default"
                                            Size="Size.Small"
                                            aria-label="@AutomatedBackupsTooltipAriaLabel"/>
                        </MudTooltip>
                    </MudStack>

                    <MudText Typo="Typo.body2"
                             Class="text-secondary">
                        @AutomatedBackupsDescriptionText
                    </MudText>
                </MudStack>

                <MudPaper Elevation="0"
                          Class="pa-3 rounded-lg">
                    <MudStack Row="true"
                              Justify="Justify.FlexEnd"
                              AlignItems="AlignItems.Center"
                              Spacing="0">
                        <MudSwitch T="bool"
                                   Value="@_automatedBackupsEnabled"
                                   ValueChanged="AutomatedBackupsEnabledChangedAsync"
                                   Disabled="@(_automatedBackupSettingsUpdateInProgress || _exportInProgress || _shareInProgress || _importInProgress)"
                                   Color="Color.Primary"
                                    aria-label="@AutomatedBackupsSwitchAriaLabel"/>
                    </MudStack>
                </MudPaper>

                <MudDivider/>

                <MudStack Spacing="1">
                    <MudStack Row="true"
                              Spacing="1"
                              AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">
                            @BackupHeaderText
                        </MudText>

                        <MudTooltip Text="@SupportNoteText"
                                    Placement="Placement.Top">
                            <MudIconButton Icon="@Icons.Material.Filled.Info"
                                           Color="Color.Default"
                                           Size="Size.Small"
                                           aria-label="@SupportTooltipAriaLabel"/>
                        </MudTooltip>
                    </MudStack>

                    <MudText Typo="Typo.body2"
                             Class="text-secondary">
                        @BackupDescriptionText
                    </MudText>
                </MudStack>

                <MudPaper Elevation="0"
                          Class="pa-3 rounded-lg">
                    <MudStack Row="true"
                              Justify="Justify.FlexEnd"
                              AlignItems="AlignItems.Center"
                              Spacing="3">
                        <MudTooltip Text="@ExportButtonTooltipText"
                                    Placement="Placement.Top">
                            <MudButton Color="Color.Primary"
                                       Variant="Variant.Filled"
                                       Disabled="@(_exportInProgress || _shareInProgress || _importInProgress)"
                                       aria-label="@ExportButtonAriaLabel"
                                       Style="@DataActionButtonStyle"
                                       OnClick="ExportDatabaseAsync">
                                @if (_exportInProgress)
                                {
                                    <MudProgressCircular Indeterminate="true"
                                                         Color="Color.Inherit"
                                                         Size="Size.Small"/>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Download"/>
                                }
                            </MudButton>
                        </MudTooltip>

                        <MudTooltip Text="@ShareButtonTooltipText"
                                    Placement="Placement.Top">
                            <span class="d-inline-flex">
                                <MudButton Color="Color.Primary"
                                           Variant="Variant.Filled"
                                           Disabled="@(!DatabaseShareService.CanShare || _exportInProgress || _shareInProgress || _importInProgress)"
                                           aria-label="@ShareButtonAriaLabel"
                                           Style="@DataActionButtonStyle"
                                           OnClick="ShareDatabaseAsync">
                                    @if (_shareInProgress)
                                    {
                                        <MudProgressCircular Indeterminate="true"
                                                             Color="Color.Inherit"
                                                             Size="Size.Small"/>
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Share"/>
                                    }
                                </MudButton>
                            </span>
                        </MudTooltip>
                    </MudStack>
                </MudPaper>

                <MudDivider/>

                <MudStack Spacing="1">
                    <MudStack Row="true"
                              Spacing="1"
                              AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">
                            @RestoreHeaderText
                        </MudText>

                        <MudTooltip Text="@RestoreWarningText"
                                    Placement="Placement.Top">
                            <MudIconButton Icon="@Icons.Material.Filled.Warning"
                                           Color="Color.Warning"
                                           Size="Size.Small"
                                           aria-label="@RestoreTooltipAriaLabel"/>
                        </MudTooltip>
                    </MudStack>

                    <MudText Typo="Typo.body2"
                             Class="text-secondary">
                        @RestoreDescriptionText
                    </MudText>
                </MudStack>

                <MudPaper Elevation="0"
                          Class="pa-3 rounded-lg">
                    <MudStack Row="true"
                              Justify="Justify.FlexEnd"
                              AlignItems="AlignItems.Center">
                        <MudTooltip Text="@ImportButtonTooltipText"
                                    Placement="Placement.Top">
                            <MudButton Color="Color.Primary"
                                       Variant="Variant.Filled"
                                       Disabled="@(_exportInProgress || _shareInProgress || _importInProgress)"
                                       aria-label="@ImportButtonAriaLabel"
                                       Style="@DataActionButtonStyle"
                                       OnClick="ImportDatabaseAsync">
                                @if (_importInProgress)
                                {
                                    <MudProgressCircular Indeterminate="true"
                                                         Color="Color.Inherit"
                                                         Size="Size.Small"/>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Upload"/>
                                }
                            </MudButton>
                        </MudTooltip>
                    </MudStack>
                </MudPaper>

            </MudStack>
        </MudPaper>
    </MudStack>
</MudContainer>

@code
{

    #region Private Fields, Properties

    private bool _exportInProgress;

    private bool _shareInProgress;

    private bool _importInProgress;

    private bool _automatedBackupsEnabled;

    private bool _automatedBackupSettingsUpdateInProgress;

    private string? _operationErrorMessage;

    #endregion

    #region Lifecycle Methods

    protected override void OnInitialized()
    {
        _automatedBackupsEnabled = AutomatedBackupConfigurationService.GetIsEnabled();
    }

    #endregion

    #region CSS Style Properties

    private const string DataActionButtonStyle = "width: 42px; min-width: 42px; height: 42px; border-radius: 999px; padding: 0;";

    #endregion

    #region Event Handlers

    private void AutomatedBackupsEnabledChangedAsync(bool isEnabled)
    {
        try
        {
            _automatedBackupSettingsUpdateInProgress = true;
            _operationErrorMessage = null;
            AutomatedBackupConfigurationService.SetIsEnabled(isEnabled);
            _automatedBackupsEnabled = isEnabled;
        }
        catch (Exception)
        {
            _operationErrorMessage = AutomatedBackupsUpdateFailedText;
            _automatedBackupsEnabled = AutomatedBackupConfigurationService.GetIsEnabled();
        }
        finally
        {
            _automatedBackupSettingsUpdateInProgress = false;
        }
    }

    private async Task ExportDatabaseAsync()
    {
        try
        {
            _exportInProgress = true;
            _operationErrorMessage = null;

            var exportResult = await DatabaseExportService.ExportDatabaseAsync();

            if (exportResult == DatabaseExportResult.Cancelled)
                return;
        }
        catch (Exception)
        {
            _operationErrorMessage = ExportFailedText;
        }
        finally
        {
            _exportInProgress = false;
        }
    }

    private async Task ShareDatabaseAsync()
    {
        try
        {
            _shareInProgress = true;
            _operationErrorMessage = null;

            await DatabaseShareService.ShareDatabaseAsync();
        }
        catch (Exception)
        {
            _operationErrorMessage = ShareFailedText;
        }
        finally
        {
            _shareInProgress = false;
        }
    }

    private async Task ImportDatabaseAsync()
    {
        try
        {
            _operationErrorMessage = null;

            var selectedBackup = await DatabaseImportFilePicker.PickBackupAsync();
            if (selectedBackup is null)
                return;

            var dialog = await DialogService.ShowAsync<RestoreDatabaseDialog>(RestoreDialogTitleText);
            var result = await dialog.Result;

            if (result is null || result.Canceled)
                return;

            _importInProgress = true;

            await DatabaseImportService.ImportDatabaseAsync(selectedBackup);

            NavigationManager.NavigateTo(RouteConstants.Home, true);
        }
        catch (InvalidDataException)
        {
            _operationErrorMessage = ImportValidationFailedText;
        }
        catch (Exception)
        {
            _operationErrorMessage = ImportFailedText;
        }
        finally
        {
            _importInProgress = false;
        }
    }

    #endregion

    #region Text, Label Properties
 
    private const string SectionEyebrowText = "Data";
 
    private const string AutomatedBackupsHeaderText = "Daily automated backups";

    private const string AutomatedBackupsDescriptionText = "Create a nightly backup in local storage.";

    private const string AutomatedBackupsTooltipText = "Runs nightly at 11:30 PM.";

    private const string AutomatedBackupsTooltipAriaLabel = "Automated backup details";

    private const string AutomatedBackupsSwitchAriaLabel = "Daily automated backups toggle";

    private const string AutomatedBackupsUpdateFailedText = "Unable to update automated backups right now. Please try again.";

    private const string BackupHeaderText = "Backup";

    private const string BackupDescriptionText = "Save or share a copy of your local data.";

    private const string ExportButtonTooltipText = "Download DB";

    private const string ExportButtonAriaLabel = "Download database";

    private const string ShareButtonTooltipText = "Share DB";

    private const string ShareButtonAriaLabel = "Share database";

    private const string SupportNoteText = "Android saves to 'Downloads' folder. Windows lets you choose where to save.";

    private const string SupportTooltipAriaLabel = "Backup save location information";

    private const string RestoreHeaderText = "Restore";

    private const string RestoreDescriptionText = "Restore your data from a previous backup.";

    private const string ImportButtonTooltipText = "Upload DB";

    private const string ImportButtonAriaLabel = "Import database";

    private const string RestoreWarningText = "This will replace ALL existing data. This action cannot be undone.";

    private const string RestoreTooltipAriaLabel = "Restore warning information";

    private const string RestoreDialogTitleText = "Restore backup";

    private const string ExportFailedText = "Unable to export your database right now. Please try again.";

    private const string ShareFailedText = "Unable to share your database right now. Please try again.";

    private const string ImportValidationFailedText = "That file is not a valid Streak backup. Your current data was not changed.";

    private const string ImportFailedText = "Unable to restore your database right now. Please try again.";

    #endregion

}
