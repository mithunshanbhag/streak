@page "/habits/{HabitId:int}"
@inject IHabitService HabitService
@inject ICheckinService CheckinService
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<PageTitle>@BrowserPageTitle</PageTitle>
<AppBarTitleScope TitleText="@AppBarTitleText"
                  LeadingEmoji="@AppBarTitleEmoji"/>

@if (_loadingData)
{
    <MudContainer MaxWidth="MaxWidth.Small"
                  Class="pa-4">
        <MudStack Style="@LoadingStateStyle"
                  Justify="Justify.Center"
                  AlignItems="AlignItems.Center">
            <MudAlert ContentAlignment="HorizontalAlignment.Center"
                      Severity="Severity.Info">
                @LoadingDataText
            </MudAlert>
        </MudStack>
    </MudContainer>
}
else if (_habitNotFound)
{
    <MudContainer MaxWidth="MaxWidth.Small"
                  Class="pa-4">
        <MudStack Spacing="3">
            <MudAlert Severity="Severity.Warning">
                @HabitNotFoundText
            </MudAlert>

            <MudButton Href="@RouteConstants.Home"
                       Variant="Variant.Outlined"
                       Color="Color.Primary">
                @BackToHabitsButtonText
            </MudButton>
        </MudStack>
    </MudContainer>
}
else if (_viewModel is not null)
{
    <MudContainer MaxWidth="MaxWidth.Small"
                  Class="pa-4">
        @if (!string.IsNullOrWhiteSpace(_deleteErrorMessage))
        {
            <MudAlert Severity="Severity.Error"
                      Dense="true"
                      Class="mb-4">
                @_deleteErrorMessage
            </MudAlert>
        }

        <MudStack Spacing="3">
            <MudPaper Elevation="1"
                      Class="pa-4 rounded-lg">
                <MudStack Spacing="3">
                    <MudStack Row="true"
                              AlignItems="AlignItems.Start"
                              Justify="Justify.SpaceBetween"
                              Wrap="Wrap.NoWrap"
                              Spacing="2"
                              Style="@SummaryHeaderStyle">
                        <MudStack Row="true"
                                  AlignItems="AlignItems.Center"
                                  Wrap="Wrap.NoWrap"
                                  Spacing="3"
                                  Style="@SummaryIdentityStyle">
                            <MudPaper Elevation="0"
                                      Class="rounded - lg"
                                      Style="@EmojiContainerStyle">
                                <MudStack AlignItems="AlignItems.Center"
                                          Justify="Justify.Center"
                                          Style="@EmojiContentStyle">
                                    @if (_viewModel.HasHabitEmoji)
                                    {
                                        <MudText Typo="Typo.h6">
                                            @_viewModel.HabitEmoji
                                        </MudText>
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Circle"
                                                 Size="Size.Small"
                                                 Color="Color.Primary"/>
                                    }
                                </MudStack>
                            </MudPaper>

                            <MudText Typo="Typo.h5"
                                     Style="@HabitNameStyle">
                                @_viewModel.HabitName
                            </MudText>
                        </MudStack>

                        <MudStack Row="true"
                                  AlignItems="AlignItems.Center"
                                  Spacing="1">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Disabled="@_deletingHabit"
                                           Color="Color.Inherit"
                                           aria-label="@EditHabitAriaLabel"
                                           OnClick="OpenEditDialogAsync"/>

                            <MudMenu Dense="true"
                                     Disabled="@_deletingHabit"
                                     Icon="@Icons.Material.Filled.MoreVert"
                                     aria-label="@MoreActionsAriaLabel">
                                <MudMenuItem Icon="@Icons.Material.Filled.Delete"
                                             OnClick="OpenDeleteDialogAsync">
                                    @DeleteHabitMenuText
                                </MudMenuItem>
                            </MudMenu>
                        </MudStack>
                    </MudStack>

                    @if (_viewModel.HasHabitDescription)
                    {
                        <MudPaper Elevation="0"
                                  Class="pa - 3 rounded - lg">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.caption"
                                         Class="text - secondary">
                                    @DescriptionLabelText
                                </MudText>

                                <MudText Typo="Typo.body2"
                                         Style="@HabitDescriptionStyle">
                                    @_viewModel.HabitDescription
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    }
                </MudStack>
            </MudPaper>

            <HabitStreakHistoryCard SummaryViewModel="@_viewModel"
                                    HistoryViewModel="@_historyViewModel"/>
        </MudStack>
    </MudContainer>
}

@code {

    #region Parameters

    [Parameter] public int HabitId { get; set; }

    #endregion

    #region Private Fields, Properties

    private HabitDetailsSummaryViewModel? _viewModel;

    private HabitHistoryHeatmapViewModel? _historyViewModel;

    private bool _loadingData;

    private bool _habitNotFound;

    private bool _deletingHabit;

    private string? _deleteErrorMessage;

    private string AppBarTitleText => _viewModel?.HabitName ?? DefaultPageTitle;

    private string? AppBarTitleEmoji => _viewModel?.HabitEmoji;

    private string BrowserPageTitle => _viewModel?.AppBarTitle ?? DefaultPageTitle;

    #endregion

    #region Lifecycle Methods

    protected override async Task OnParametersSetAsync()
    {
        await LoadDataAsync();
    }

    #endregion

    #region Event Handlers

    private async Task OpenDeleteDialogAsync()
    {
        if (_viewModel is null)
            throw new InvalidOperationException("Cannot open the delete dialog before the habit details are loaded.");

        var dialog = await DialogService.ShowAsync<DeleteHabitDialog>(
            DeleteDialogTitleText,
            CreateDeleteDialogParameters(_viewModel));

        var result = await dialog.Result;
        if (result is null || result.Canceled)
            return;

        if (result.Data is not int confirmedHabitId)
            throw new InvalidOperationException("Delete dialog did not return the confirmed habit identifier.");

        await DeleteHabitAsync(confirmedHabitId);
    }

    private async Task OpenEditDialogAsync()
    {
        if (_viewModel is null)
            throw new InvalidOperationException("Cannot open the edit dialog before the habit details are loaded.");

        var dialog = await DialogService.ShowAsync<EditHabitDialog>(
            EditDialogTitleText,
            CreateEditDialogParameters(_viewModel));

        var result = await dialog.Result;
        if (result is null || result.Canceled)
            return;

        if (result.Data is not Habit updatedHabit)
            throw new InvalidOperationException("Edit dialog did not return the updated habit.");

        await RefreshHabitDetailsAsync(updatedHabit);
    }

    #endregion

    #region Private Helper Methods

    private async Task LoadDataAsync()
    {
        _loadingData = true;
        _habitNotFound = false;
        _deleteErrorMessage = null;
        _viewModel = null;
        _historyViewModel = null;

        try
        {
            if (HabitId <= 0)
            {
                _habitNotFound = true;
                return;
            }

            var habit = await HabitService.GetByIdAsync(HabitId);
            if (habit is null)
            {
                _habitNotFound = true;
                return;
            }

            var streakTask = CheckinService.GetCurrentStreakAsync(habit.Name);
            var historyTask = CheckinService.GetHistoryAsync(habit.Name);

            await Task.WhenAll(streakTask, historyTask);

            var streak = await streakTask;

            _viewModel = new HabitDetailsSummaryViewModel
            {
                HabitId = habit.Id,
                HabitName = habit.Name,
                HabitEmoji = habit.Emoji,
                HabitDescription = habit.Description,
                Streak = streak
            };

            _historyViewModel = HabitHistoryHeatmapBuilder.Build(
                await historyTask,
                DateOnly.FromDateTime(DateTime.Now));
        }
        finally
        {
            _loadingData = false;
        }
    }

    private async Task DeleteHabitAsync(int confirmedHabitId)
    {
        if (_viewModel is null)
            throw new InvalidOperationException("Cannot delete a habit before the habit details are loaded.");

        if (confirmedHabitId != _viewModel.HabitId)
            throw new InvalidOperationException("Delete confirmation did not match the currently loaded habit.");

        _deleteErrorMessage = null;
        _deletingHabit = true;

        try
        {
            await HabitService.DeleteAsync(confirmedHabitId);
            NavigationManager.NavigateTo(RouteConstants.Home);
        }
        catch (KeyNotFoundException)
        {
            _deleteErrorMessage = HabitAlreadyDeletedText;
        }
        catch (InvalidOperationException)
        {
            _deleteErrorMessage = DeleteHabitFailedText;
        }
        finally
        {
            _deletingHabit = false;
        }
    }

    private static DialogParameters<DeleteHabitDialog> CreateDeleteDialogParameters(HabitDetailsSummaryViewModel viewModel)
    {
        return new DialogParameters<DeleteHabitDialog>
        {
            { x => x.HabitId, viewModel.HabitId },
            { x => x.HabitName, viewModel.HabitName }
        };
    }

    private static DialogParameters<EditHabitDialog> CreateEditDialogParameters(HabitDetailsSummaryViewModel viewModel)
    {
        return new DialogParameters<EditHabitDialog>
        {
            { x => x.HabitId, viewModel.HabitId },
            { x => x.HabitName, viewModel.HabitName },
            { x => x.HabitEmoji, viewModel.HabitEmoji },
            { x => x.HabitDescription, viewModel.HabitDescription }
        };
    }

    private async Task RefreshHabitDetailsAsync(Habit updatedHabit)
    {
        if (_viewModel is null)
            throw new InvalidOperationException("Cannot refresh the habit details before the page is loaded.");

        if (updatedHabit.Id != _viewModel.HabitId)
            throw new InvalidOperationException("Edit dialog returned a different habit than the one currently being viewed.");

        await LoadDataAsync();
    }

    #endregion

    #region CSS Style Properties

    private const string SummaryHeaderStyle = "min-width: 0;";

    private const string SummaryIdentityStyle = "min-width: 0; flex: 1 1 auto;";

    private const string EmojiContainerStyle = "width: 48px; height: 48px; background-color: var(--mud-palette-primary-hover); flex-shrink: 0;";

    private const string EmojiContentStyle = "width: 48px; height: 48px;";

    private const string HabitNameStyle = "overflow: hidden; text-overflow: ellipsis; white-space: nowrap;";

    private const string HabitDescriptionStyle = "white-space: pre-wrap;";

    private const string LoadingStateStyle = "min-height: 80vh";

    #endregion

    #region Text, Label Properties

    private const string DefaultPageTitle = "Habit Details";

    private const string LoadingDataText = "Loading habit details...";

    private const string HabitNotFoundText = "Habit not found.";

    private const string BackToHabitsButtonText = "Back to habits";

    private const string DeleteDialogTitleText = "Delete habit";

    private const string EditDialogTitleText = "Edit habit";

    private const string DeleteHabitMenuText = "Delete habit";

    private const string DescriptionLabelText = "Description";

    private const string EditHabitAriaLabel = "Edit habit";

    private const string MoreActionsAriaLabel = "More habit actions";

    private const string HabitAlreadyDeletedText = "This habit no longer exists.";

    private const string DeleteHabitFailedText = "Unable to delete this habit right now. Please try again.";

    #endregion

}
